//@version=6

// ═════════════════════════════════════════════════════════════════════════════
//  The ORB Experiment  |  Pine Script v6
//  Chart     : trade on 5-minute; ORB box + midpoint also render on ANY timeframe
//  ORB Source: 08:00 AM ET window, length user-selectable (5/10/15/20/30/60 min)
//  Session   : 8:00 AM ET open  |  Reset: 18:00 ET
//  Instruments: MES & MNQ (commission/capital reference) — also NQ, ES, YM, MYM, GC, MGC
//
//  Entry logic (short; long mirrors):
//    1. Breakout : two CONSECUTIVE bars both body-close below ORB low (any color)
//    2. Liquidity: structural level = high of most recent green→red pair
//                  (falls back to the most recent pre-8AM green→red high)
//    3. Revisit  : price must touch BOTH the structural level AND the ORB band
//                  (any order)
//    4. Floor    : once revisits done, floor = low of most recent red→green pair
//    5. Transfer : floor re-syncs to each new red→green pair (up or down) AND
//                  moves down on a wick that pierces it without a body-close-below
//    6. Entry    : a bearish bar body-closes below the valid floor
//
//  Trade mgmt: SL = entry candle body open | TP = 2:1 RR | BE at 1:1 RR
//  Backtest  : $50K start | comm $0.80/side + 1-tick slippage (Tradovate MES/MNQ) | 5% margin
//  ONE trade per day (all instruments), taken only between 8:00 AM–12:00 PM ET.
//  After that trade CLOSES, all setup drawing stops (ORB box/mid keep going).
// ═════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────────────────
//  INPUTS  (defined before strategy() so they're available at declaration)
// ─────────────────────────────────────────────────────────────────────────────

// ── Backtest Settings ────────────────────────────────────────────────────────
i_commission = input.float(
    0.80, "Commission Per Side ($) — MES/MNQ", minval=0, step=0.01,
    group="⚙️ Backtest Settings",
    tooltip="Display reference only. The LIVE value is baked into strategy(commission_value) below = $0.80/side: a rounded-up all-in for MES & MNQ micros on Tradovate (Free-plan base ≈ $0.72 = $0.39 commission + $0.22 exchange + $0.09 clearing + $0.02 NFA). Round turn ≈ $1.60. Paid Tradovate plans are cheaper — override in Strategy Settings → Properties → Commission if needed.")

i_slippage = input.int(
    1, "Slippage (Ticks)", minval=0,
    group="⚙️ Backtest Settings",
    tooltip="Display reference only. The LIVE value is baked into strategy(slippage=1) below = 1 tick per fill. Override in Strategy Settings → Properties → Slippage if needed.")

// Trading rules are global (same for every instrument): one trade per day,
// taken only between 8:00 AM and 12:00 PM ET. See TRADING WINDOW + DAILY CAP.

// ── ORB Settings ─────────────────────────────────────────────────────────────
i_orb_minutes = input.int(
    15, "ORB Duration (min)", options=[5, 10, 15, 20, 30, 60],
    group="📐 ORB Settings",
    tooltip="Length of the opening range, anchored at 8:00 AM ET. 5 = 08:00–08:05, 15 = 08:00–08:15 (default), 60 = 08:00–09:00. The trade engine always runs on 5-minute candles regardless of this choice.")

i_orb_end = input.int(
    1700, "ORB Box End Time (HHMM ET)", minval=800, maxval=2359,
    group="📐 ORB Settings",
    tooltip="ORB box and midpoint line extend rightward until this time. Default 17:00 ET.")

i_move_sl_to_be = input.bool(true, "Move SL to Breakeven at 1R", group="📐 ORB Settings",
    tooltip="When OFF, the stop loss stays at its original level for the entire trade (no move to entry at 1:1 RR).")

i_custom_sl_tp = input.bool(false, "Enable Custom SL/TP Multiples", group="📐 ORB Settings",
    tooltip="When ON, SL and TP are set as user-defined multiples of the trigger candle's range (|close-open|), overriding the default SL=candle open / TP=2R.")

i_reverse_signals = input.bool(false, "Reverse Signals (Buy↔Sell)", group="📐 ORB Settings",
    tooltip="When ON, a buy trigger opens a SHORT instead and a sell trigger opens a LONG instead. SL/TP are mirrored to match the reversed direction.")

i_sl_mult = input.float(1.0, "SL Multiple (x candle range)", minval=0.01, step=0.1, group="📐 ORB Settings",
    tooltip="Only used when 'Enable Custom SL/TP Multiples' is ON.")

i_tp_mult = input.float(2.0, "TP Multiple (x candle range)", minval=0.01, step=0.1, group="📐 ORB Settings",
    tooltip="Only used when 'Enable Custom SL/TP Multiples' is ON.")

// ── Visuals ───────────────────────────────────────────────────────────────────
i_show_levels = input.bool(true,  "Show Level Lines (liquidity + floor/ceiling)", group="👁 Visuals")
i_show_volume = input.bool(false, "Show Volume Context",     group="👁 Visuals")
i_show_vwap   = input.bool(false, "Show VWAP",               group="👁 Visuals")
i_show_pdhl   = input.bool(false, "Show Prior Day High/Low", group="👁 Visuals")
i_vol_lookback = input.int(20, "Volume Avg Lookback (bars)", minval=5, maxval=100,
    group="👁 Visuals",
    tooltip="Bars used to compute average volume for context display.")

// ── Colors ────────────────────────────────────────────────────────────────────
i_col_orb_box = input.color(color.new(color.blue,  80), "ORB Box",          group="🎨 Colors")
i_col_orb_mid = input.color(color.new(color.blue,  30), "ORB Midpoint",     group="🎨 Colors")
i_col_liq     = input.color(color.white,                "Liquidity Level",  group="🎨 Colors")
i_col_floor   = input.color(color.orange,               "Floor / Ceiling",  group="🎨 Colors")
i_col_vwap    = input.color(color.new(color.purple, 0), "VWAP",             group="🎨 Colors")
i_col_pdhl    = input.color(color.new(color.gray,   0), "Prior Day H/L",    group="🎨 Colors")
i_col_vol_hi  = input.color(color.new(color.yellow, 0), "Volume Spike",     group="🎨 Colors")

// ── Optimizer ─────────────────────────────────────────────────────────────────
i_optimize = input.bool(false, "Show SL/TP Optimization Table", group="🔬 Optimizer",
    tooltip="When ON, draws a grid that tests every SL×TP multiple combo on the SAME entries the strategy takes. R = initial stop risk (|entry − SL| × point value). Respects the BE-at-1R toggle + 4:45 EOD flatten. Does NOT change the strategy's own trades — advisory only. Tip: shorten the backtest date range if it runs slowly.")

i_goal = input.string("Expectancy (R)", "Optimization Goal", group="🔬 Optimizer",
    options=["Expectancy (R)", "Calmar (R)", "Win Rate %"],
    tooltip="Which metric drives the heatmap coloring and best-cell detection.\n• Expectancy (R): avg R earned per trade — the core edge metric.\n• Calmar (R): total R ÷ max drawdown R — rewards consistent gains, punishes blow-up combos.\n• Win Rate %: % of trades that closed profitable.")

i_min_trades = input.int(30, "Min Trades (sample gate)", minval=1, group="🔬 Optimizer",
    tooltip="Cells with fewer than this many trades are greyed out and ineligible for 'best'. Rule of thumb: 30 trades gives ±9 pp standard error on win rate (95% CI); 50 is comfortable; 100 is publication-grade. Below 30 the ranking is largely noise.")

i_min_losses = input.int(5, "Min Losing Trades (sample gate)", minval=0, group="🔬 Optimizer",
    tooltip="Cells with fewer losing trades than this are greyed out. Calmar and drawdown metrics are unstable when losses are too few — the denominator is near zero and any single loss dominates the result.")

strategy("The ORB Experiment", overlay=true, process_orders_on_close=true,
    pyramiding=2, max_bars_back=500, max_lines_count=500,
    default_qty_type=strategy.fixed, default_qty_value=1,
    initial_capital=50000,
    commission_type=strategy.commission.cash_per_contract, commission_value=0.80,
    slippage=1, margin_long=5, margin_short=5)

// ─────────────────────────────────────────────────────────────────────────────
//  TIME UTILITIES
// ─────────────────────────────────────────────────────────────────────────────

int et_hour       = hour(time,   "America/New_York")
int et_minute     = minute(time, "America/New_York")
int et_hhmm       = et_hour * 100 + et_minute
int et_min_of_day = et_hour * 60 + et_minute

// Selectable opening-range window, anchored at 08:00 ET. Minutes-of-day math
// avoids HHMM carry bugs (e.g. 60m ends at 09:00). All durations are multiples
// of 5 → each window is a whole number of 5m bars.
int orb_start_min = 480                  // 08:00 ET
int orb_end_min   = 480 + i_orb_minutes  // window end (exclusive)

bool in_orb_window = et_min_of_day >= orb_start_min and et_min_of_day < orb_end_min
bool new_session   = et_hour == 18 and et_minute == 0

// ─────────────────────────────────────────────────────────────────────────────
//  CROSS-TIMEFRAME ORB  (drawing only — NEVER feeds the trade engine)
//  Self-contained 5-minute rebuild of the same opening range, pulled below via
//  request.security("5", …, lookahead_off) so the ORB box + midpoint render
//  identically on any chart timeframe. Own 18:00 reset → can never capture the
//  prior session's range (the bug that killed the old request.security build).
// ─────────────────────────────────────────────────────────────────────────────

f_orb_box() =>
    var float fh   = na
    var float fl   = na
    var float fm   = na
    var int   ftm  = na    // time of the 08:00 bar (box left edge)
    var bool  fset = false
    int fhh  = hour(time,   "America/New_York")
    int fmm  = minute(time, "America/New_York")
    int fmod = fhh * 60 + fmm
    if fhh == 18 and fmm == 0
        fh   := na
        fl   := na
        fm   := na
        ftm  := na
        fset := false
    if fmod == orb_start_min and not fset
        fh  := high
        fl  := low
        ftm := time
    else if fmod > orb_start_min and fmod < orb_end_min and not fset and not na(fh)
        fh := math.max(fh, high)
        fl := math.min(fl, low)
    if fmod == orb_end_min - 5 and not fset and not na(fh)
        fm   := (fh + fl) / 2
        fset := true
    [fh, fl, fm, ftm, fset]

// ─────────────────────────────────────────────────────────────────────────────
//  TRADING WINDOW + DAILY CAP  (global — identical for every instrument)
//  One trade per day, taken only between 8:00 AM and 12:00 PM ET.
// ─────────────────────────────────────────────────────────────────────────────

int  max_trades = 1
bool time_ok    = et_hhmm >= 800 and et_hhmm < 1200

// ─────────────────────────────────────────────────────────────────────────────
//  STATE VARIABLES
// ─────────────────────────────────────────────────────────────────────────────

// ORB
var bool  orb_set    = false
var float orb_high   = na
var float orb_low    = na
var float orb_mid    = na
var int   orb_anchor = na   // bar_index of the 08:00 bar (box left edge)

// Candle-pair levels (tracked every bar, incl. pre-8AM, for fallback)
//   gr_high = high of most recent green→red (bullish→bearish) pair
//   rg_low  = low  of most recent red→green (bearish→bullish) pair
var float gr_high = na
var float rg_low  = na

// Breakout (two consecutive body-closes beyond ORB)
var bool bear_brk = false
var bool bull_brk = false

// Dual-revisit gates (structural level + ORB band)
var bool rev_struct_short = false
var bool rev_orb_short    = false
var bool rev_struct_long  = false
var bool rev_orb_long      = false

// Armed + locked trigger levels
var bool  armed_short    = false
var bool  armed_long     = false
var bool  floor_set      = false
var bool  ceil_set       = false
var float floor_short    = na
var float ceil_long      = na

// Session trade counter
var int entry_count = 0

// True once the day's one trade has CLOSED — suppresses further setup drawing
var bool day_complete = false

// BE management — slot 1 and slot 2 (max 2 simultaneous via pyramiding=2)
var float  s1_entry   = na
var float  s1_sl      = na
var float  s1_tp      = na
var bool   s1_be_done = false
var bool   s1_is_long = true
var string s1_id      = ""

var float  s2_entry   = na
var float  s2_sl      = na
var float  s2_tp      = na
var bool   s2_be_done = false
var bool   s2_is_long = true
var string s2_id      = ""

// Visual objects (persist for extending)
var box  orb_box_obj  = na
var line orb_mid_line = na
var line liq_line_s   = na
var line floor_line_s = na
var line liq_line_l   = na
var line ceil_line_l  = na

// ─────────────────────────────────────────────────────────────────────────────
//  SESSION RESET  (18:00 ET — futures new session)
// ─────────────────────────────────────────────────────────────────────────────

if new_session
    orb_set          := false
    orb_high         := na
    orb_low          := na
    orb_mid          := na
    orb_anchor       := na
    gr_high          := na
    rg_low           := na
    bear_brk         := false
    bull_brk         := false
    rev_struct_short := false
    rev_orb_short    := false
    rev_struct_long  := false
    rev_orb_long     := false
    armed_short      := false
    armed_long       := false
    floor_set        := false
    ceil_set         := false
    floor_short      := na
    ceil_long        := na
    entry_count      := 0
    day_complete     := false
    s1_entry         := na
    s1_sl            := na
    s1_tp            := na
    s1_be_done       := false
    s1_id            := ""
    s2_entry         := na
    s2_sl            := na
    s2_tp            := na
    s2_be_done       := false
    s2_id            := ""
    orb_box_obj      := na
    orb_mid_line     := na
    liq_line_s       := na
    floor_line_s     := na
    liq_line_l       := na
    ceil_line_l      := na

// ─────────────────────────────────────────────────────────────────────────────
//  ORB BUILD  (native 5m aggregation over the selected 08:00-based window)
//  Accumulate high/low across every 5m bar in [orb_start_min, orb_end_min);
//  latch complete on the final in-window bar so the range is set before use.
// ─────────────────────────────────────────────────────────────────────────────

if et_min_of_day == orb_start_min and not orb_set
    orb_high   := high
    orb_low    := low
    orb_anchor := bar_index
else if et_min_of_day > orb_start_min and et_min_of_day < orb_end_min and not orb_set and not na(orb_high)
    orb_high := math.max(orb_high, high)
    orb_low  := math.min(orb_low,  low)

if et_min_of_day == orb_end_min - 5 and not orb_set and not na(orb_high)
    orb_mid := (orb_high + orb_low) / 2
    orb_set := true

// ─────────────────────────────────────────────────────────────────────────────
//  CANDLE-PAIR TRACKING  (every bar — feeds liquidity levels + floor/ceiling)
// ─────────────────────────────────────────────────────────────────────────────

bool prev_bull = close[1] > open[1]
bool prev_bear = close[1] < open[1]
bool cur_bull  = close > open
bool cur_bear  = close < open

bool pair_gr = prev_bull and cur_bear   // green → red  (bullish → bearish)
bool pair_rg = prev_bear and cur_bull   // red → green  (bearish → bullish)

if pair_gr
    gr_high := math.max(high, high[1])
if pair_rg
    rg_low  := math.min(low,  low[1])

// ─────────────────────────────────────────────────────────────────────────────
//  BREAKOUT  (two CONSECUTIVE bearish/bullish bars body-close beyond ORB)
// ─────────────────────────────────────────────────────────────────────────────

if orb_set and not in_orb_window
    // Two consecutive body-closes beyond the ORB edge. Candle COLOR does not
    // matter — only that the close is outside the range, twice in a row.
    bool bear_now  = close   < orb_low
    bool bear_prev = close[1] < orb_low
    bool bull_now  = close   > orb_high
    bool bull_prev = close[1] > orb_high
    if not bear_brk and bear_now and bear_prev
        bear_brk := true
    if not bull_brk and bull_now and bull_prev
        bull_brk := true

// ─────────────────────────────────────────────────────────────────────────────
//  DUAL REVISIT  (structural level + ORB band — any order, evaluated AFTER break)
//  bear_brk[1] / bull_brk[1] = breakout already valid as of the prior bar,
//  so the breakout candle itself can't satisfy the revisit
// ─────────────────────────────────────────────────────────────────────────────

if bear_brk[1]
    if not rev_struct_short and not na(gr_high) and high >= gr_high
        rev_struct_short := true
    if not rev_orb_short and high >= orb_low
        rev_orb_short := true

if bull_brk[1]
    if not rev_struct_long and not na(rg_low) and low <= rg_low
        rev_struct_long := true
    if not rev_orb_long and low <= orb_high
        rev_orb_long := true

// ─────────────────────────────────────────────────────────────────────────────
//  ARM + LOCK TRIGGER LEVEL + TRANSFER
//  Short floor  = low of most recent red→green pair; locked at arming, then
//    (a) re-syncs to each new red→green pair (up or down), and
//    (b) transfers DOWN on any wick that pierces it without a body-close-below.
//  Long ceiling = high of most recent green→red pair; locked at arming, then
//    (a) re-syncs to each new green→red pair (up or down), and
//    (b) transfers UP on any wick that pierces it without a body-close-above.
//  Re-sync runs first; the later event on a given bar governs.
// ─────────────────────────────────────────────────────────────────────────────

if not armed_short and bear_brk and rev_struct_short and rev_orb_short
    armed_short := true
if armed_short and not floor_set and not na(rg_low)
    floor_short := rg_low
    floor_set   := true
if floor_set and pair_rg
    floor_short := rg_low
if floor_set and not na(floor_short) and low < floor_short and close >= floor_short
    floor_short := low

if not armed_long and bull_brk and rev_struct_long and rev_orb_long
    armed_long := true
if armed_long and not ceil_set and not na(gr_high)
    ceil_long := gr_high
    ceil_set  := true
if ceil_set and pair_gr
    ceil_long := gr_high
if ceil_set and not na(ceil_long) and high > ceil_long and close <= ceil_long
    ceil_long := high

// ─────────────────────────────────────────────────────────────────────────────
//  ENTRY TRIGGER
// ─────────────────────────────────────────────────────────────────────────────

bool bull_bar = close > open
bool bear_bar = close < open

bool s_armed = armed_short and floor_set and not na(floor_short)
bool s_trig  = bear_bar and close < floor_short
bool s_room  = entry_count < max_trades and time_ok
bool sell_signal = s_armed and s_trig and s_room

bool l_armed = armed_long and ceil_set and not na(ceil_long)
bool l_trig  = bull_bar and close > ceil_long
bool l_room  = entry_count < max_trades and time_ok
bool buy_signal = l_armed and l_trig and l_room

// Optimizer entry hooks — capture the entry (price/direction/R) for the SL/TP
// optimizer block at the end of the file. Set on any real entry; consumed only
// when i_optimize is ON. Reset to defaults every bar.
bool  opt_fire   = false
float opt_entry  = na
bool  opt_islong = false
float opt_R      = na

// ── Long-trigger entry (buy_signal) ─────────────────────────────────────────
// Normally opens a LONG; if i_reverse_signals is ON, opens a SHORT instead
// with mirrored SL/TP.
if buy_signal
    float _r  = math.abs(close - open)
    bool  _go_long = not i_reverse_signals
    opt_fire   := true
    opt_entry  := close
    opt_islong := _go_long
    opt_R      := _r
    float _sl_long  = i_custom_sl_tp ? close - i_sl_mult * _r : open
    float _sl_short = i_custom_sl_tp ? close + i_sl_mult * _r : close + _r
    float _tp_long  = i_custom_sl_tp ? close + i_tp_mult * _r : close + 2.0 * _r
    float _tp_short = i_custom_sl_tp ? close - i_tp_mult * _r : close - 2.0 * _r
    float _sl = _go_long ? _sl_long : _sl_short
    float _tp = _go_long ? _tp_long : _tp_short
    string _id = "L" + str.tostring(entry_count + 1)
    strategy.entry(_id, _go_long ? strategy.long : strategy.short)
    strategy.exit(_id + "x", _id, stop=_sl, limit=_tp)
    if na(s1_entry)
        s1_entry   := close
        s1_sl      := _sl
        s1_tp      := _tp
        s1_be_done := false
        s1_is_long := _go_long
        s1_id      := _id
    else
        s2_entry   := close
        s2_sl      := _sl
        s2_tp      := _tp
        s2_be_done := false
        s2_is_long := _go_long
        s2_id      := _id
    entry_count := entry_count + 1
    // reset long setup so re-entry needs a fresh revisit + ceiling
    armed_long      := false
    rev_struct_long := false
    rev_orb_long    := false
    ceil_set        := false
    ceil_long       := na
    liq_line_l      := na
    ceil_line_l     := na

// ── Short-trigger entry (sell_signal) ───────────────────────────────────────
// Normally opens a SHORT; if i_reverse_signals is ON, opens a LONG instead
// with mirrored SL/TP.
if sell_signal
    float _r  = math.abs(close - open)
    bool  _go_long = i_reverse_signals
    opt_fire   := true
    opt_entry  := close
    opt_islong := _go_long
    opt_R      := _r
    float _sl_long  = i_custom_sl_tp ? close - i_sl_mult * _r : close - _r
    float _sl_short = i_custom_sl_tp ? close + i_sl_mult * _r : open
    float _tp_long  = i_custom_sl_tp ? close + i_tp_mult * _r : close + 2.0 * _r
    float _tp_short = i_custom_sl_tp ? close - i_tp_mult * _r : close - 2.0 * _r
    float _sl = _go_long ? _sl_long : _sl_short
    float _tp = _go_long ? _tp_long : _tp_short
    string _id = "S" + str.tostring(entry_count + 1)
    strategy.entry(_id, _go_long ? strategy.long : strategy.short)
    strategy.exit(_id + "x", _id, stop=_sl, limit=_tp)
    if na(s1_entry)
        s1_entry   := close
        s1_sl      := _sl
        s1_tp      := _tp
        s1_be_done := false
        s1_is_long := _go_long
        s1_id      := _id
    else
        s2_entry   := close
        s2_sl      := _sl
        s2_tp      := _tp
        s2_be_done := false
        s2_is_long := _go_long
        s2_id      := _id
    entry_count := entry_count + 1
    // reset short setup so re-entry needs a fresh revisit + floor
    armed_short      := false
    rev_struct_short := false
    rev_orb_short    := false
    floor_set        := false
    floor_short      := na
    liq_line_s       := na
    floor_line_s     := na

// ─────────────────────────────────────────────────────────────────────────────
//  EOD FLATTEN  (force-close any open position by 4:45 PM ET)
// ─────────────────────────────────────────────────────────────────────────────

if et_hhmm == 1645 and strategy.position_size != 0
    strategy.close_all(comment="EOD Flatten")

// ─────────────────────────────────────────────────────────────────────────────
//  BREAKEVEN MANAGEMENT  (move SL to entry when 1:1 RR reached)
// ─────────────────────────────────────────────────────────────────────────────

if i_move_sl_to_be and not na(s1_entry) and not s1_be_done and s1_id != ""
    float _r  = math.abs(s1_entry - s1_sl)
    bool  hit = s1_is_long ? high >= s1_entry + _r : low <= s1_entry - _r
    if hit
        strategy.exit(s1_id + "x", s1_id, stop=s1_entry, limit=s1_tp)
        s1_be_done := true

if i_move_sl_to_be and not na(s2_entry) and not s2_be_done and s2_id != ""
    float _r  = math.abs(s2_entry - s2_sl)
    bool  hit = s2_is_long ? high >= s2_entry + _r : low <= s2_entry - _r
    if hit
        strategy.exit(s2_id + "x", s2_id, stop=s2_entry, limit=s2_tp)
        s2_be_done := true

// ─────────────────────────────────────────────────────────────────────────────
//  POSITION CLOSE HANDLING  (BE stop-out or TP hit)
//  Clear slots + reset both setups so a fresh setup can build for re-entry
// ─────────────────────────────────────────────────────────────────────────────

bool pos_closed = strategy.position_size == 0 and
                  strategy.position_size[1] != 0 and
                  not new_session

if pos_closed
    day_complete     := true
    s1_entry         := na
    s1_sl            := na
    s1_tp            := na
    s1_be_done       := false
    s1_id            := ""
    s2_entry         := na
    s2_sl            := na
    s2_tp            := na
    s2_be_done       := false
    s2_id            := ""
    armed_short      := false
    armed_long       := false
    rev_struct_short := false
    rev_orb_short    := false
    rev_struct_long  := false
    rev_orb_long     := false
    floor_set        := false
    ceil_set         := false
    floor_short      := na
    ceil_long        := na
    liq_line_s       := na
    floor_line_s     := na
    liq_line_l       := na
    ceil_line_l      := na

// ─────────────────────────────────────────────────────────────────────────────
//  ORB VISUALS  (box + midpoint — time-anchored so they render on ANY timeframe)
//  Values come from the cross-timeframe 5m calc (NOT the native engine ORB), so
//  the box is identical whether the chart is 1m, 5m, 15m, or 1h. Time coordinates
//  (xloc.bar_time) place the box correctly regardless of the chart's bar size.
// ─────────────────────────────────────────────────────────────────────────────

[box_oh, box_ol, box_om, box_otime, box_oset] = request.security(
    syminfo.tickerid, "5", f_orb_box(),
    gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

if box_oset and na(orb_box_obj) and not na(box_otime)
    orb_box_obj  := box.new(box_otime, box_oh, time_close, box_ol, xloc=xloc.bar_time,
                             border_color=i_col_orb_box, bgcolor=i_col_orb_box)
    orb_mid_line := line.new(box_otime, box_om, time_close, box_om, xloc=xloc.bar_time,
                              color=i_col_orb_mid, style=line.style_dashed, width=1)

if box_oset and not na(orb_box_obj) and et_hhmm <= i_orb_end
    box.set_right(orb_box_obj, time_close)
    line.set_x2(orb_mid_line, time_close)

// ─────────────────────────────────────────────────────────────────────────────
//  LEVEL LINE VISUALS  (liquidity level while waiting, floor/ceiling once locked)
// ─────────────────────────────────────────────────────────────────────────────

// Short liquidity level (the structural high to revisit) — drawn until revisited
if i_show_levels and not day_complete and bear_brk and not rev_struct_short and not na(gr_high)
    if na(liq_line_s)
        liq_line_s := line.new(bar_index, gr_high, bar_index + 1, gr_high,
            color=i_col_liq, style=line.style_dashed, width=1)
    else
        line.set_y1(liq_line_s, gr_high)
        line.set_y2(liq_line_s, gr_high)
        line.set_x2(liq_line_s, bar_index + 1)

// Short floor (trigger) — drawn + transferred while armed
if i_show_levels and not day_complete and floor_set and not na(floor_short)
    if na(floor_line_s)
        floor_line_s := line.new(bar_index, floor_short, bar_index + 1, floor_short,
            color=i_col_floor, style=line.style_dashed, width=1)
    else
        line.set_y1(floor_line_s, floor_short)
        line.set_y2(floor_line_s, floor_short)
        line.set_x2(floor_line_s, bar_index + 1)

// Long liquidity level (the structural low to revisit) — drawn until revisited
if i_show_levels and not day_complete and bull_brk and not rev_struct_long and not na(rg_low)
    if na(liq_line_l)
        liq_line_l := line.new(bar_index, rg_low, bar_index + 1, rg_low,
            color=i_col_liq, style=line.style_dashed, width=1)
    else
        line.set_y1(liq_line_l, rg_low)
        line.set_y2(liq_line_l, rg_low)
        line.set_x2(liq_line_l, bar_index + 1)

// Long ceiling (trigger) — drawn + transferred while armed
if i_show_levels and not day_complete and ceil_set and not na(ceil_long)
    if na(ceil_line_l)
        ceil_line_l := line.new(bar_index, ceil_long, bar_index + 1, ceil_long,
            color=i_col_floor, style=line.style_dashed, width=1)
    else
        line.set_y1(ceil_line_l, ceil_long)
        line.set_y2(ceil_line_l, ceil_long)
        line.set_x2(ceil_line_l, bar_index + 1)

// ─────────────────────────────────────────────────────────────────────────────
//  REFERENCE LINES  (VWAP + Prior Day High/Low)
// ─────────────────────────────────────────────────────────────────────────────

float vwap_val = ta.vwap(hlc3)
plot(i_show_vwap ? vwap_val : na, "VWAP", color=i_col_vwap, linewidth=1)

float pdh_val = request.security(syminfo.tickerid, "D",
    high[1], barmerge.gaps_off, barmerge.lookahead_off)
float pdl_val = request.security(syminfo.tickerid, "D",
    low[1],  barmerge.gaps_off, barmerge.lookahead_off)

plot(i_show_pdhl ? pdh_val : na, "PDH",
    color=i_col_pdhl, style=plot.style_stepline, linewidth=1)
plot(i_show_pdhl ? pdl_val : na, "PDL",
    color=i_col_pdhl, style=plot.style_stepline, linewidth=1)

// ─────────────────────────────────────────────────────────────────────────────
//  VOLUME CONTEXT  (visual only — not an entry filter)
//  Highlights entry candle background when volume exceeds session average
// ─────────────────────────────────────────────────────────────────────────────

float vol_avg   = ta.sma(volume, i_vol_lookback)
bool  vol_spike = volume > vol_avg

bgcolor(i_show_volume and not day_complete and (buy_signal or sell_signal) and vol_spike
    ? color.new(i_col_vol_hi, 75) : na)

// Dim the chart background when the optimizer table is open to reduce visual clutter
bgcolor(i_optimize ? color.new(color.black, 70) : na)

// ─────────────────────────────────────────────────────────────────────────────
//  SL/TP OPTIMIZER  (advisory grid — gated on i_optimize; NEVER changes trades)
//  Tests every SL×TP multiple combo (SL 0.2→3.0, TP 0.2→5.0, step 0.2 = 15×25)
//  on the SAME entries the live strategy takes. R = |close−open| of trigger candle.
//  Metrics are R-based: 1R = |entry−SL| × pointvalue, fixed at entry (BE moves don't
//  change it). Expectancy(R) = avg R/trade. Calmar(R) = total R ÷ max drawdown R.
//  Sample gate: cells with < i_min_trades or < i_min_losses are greyed out (ineligible).
//  Heatmap: relative green→red gradient. Plateau ★ = all 4 neighbors within 10%.
//  Intrabar tie (SL & TP both inside one bar) resolves to SL (pessimistic).
// ─────────────────────────────────────────────────────────────────────────────

int N_SL     = 15
int N_TP     = 25
int N_COMBOS = 375

var a_open    = array.new_bool (N_COMBOS, false)
var a_entry2  = array.new_float(N_COMBOS, na)
var a_efill   = array.new_float(N_COMBOS, na)
var a_sl2     = array.new_float(N_COMBOS, na)
var a_tp2     = array.new_float(N_COMBOS, na)
var a_risk    = array.new_float(N_COMBOS, na)   // initial stop risk in price pts (|entry-SL|)
var a_initR   = array.new_float(N_COMBOS, na)   // 1R in dollars at entry (risk_pts × pointvalue)
var a_long    = array.new_bool (N_COMBOS, false)
var a_bedone  = array.new_bool (N_COMBOS, false)
var a_trades  = array.new_int  (N_COMBOS, 0)
var a_wins    = array.new_int  (N_COMBOS, 0)
var a_losses  = array.new_int  (N_COMBOS, 0)    // losing trade count for sample gate
// R-based accumulators (all 3 metrics computed always)
var a_sumR    = array.new_float(N_COMBOS, 0.0)  // sum of R multiples (for Expectancy R)
var a_peakR   = array.new_float(N_COMBOS, 0.0)  // peak R-equity (for Calmar R)
var a_equityR = array.new_float(N_COMBOS, 0.0)  // running R-equity curve
var a_maxddR  = array.new_float(N_COMBOS, 0.0)  // max drawdown in R
var int   opt_open_count = 0
var table opt_tbl        = na

if i_optimize
    // Create the table ONCE (never delete+recreate — that left it blank/gone on
    // recalcs). We only repopulate its cells on the render bar below.
    if na(opt_tbl)
        opt_tbl := table.new(position.middle_center, N_TP + 1, N_SL + 1,
             border_width=1, border_color=color.new(color.gray, 50),
             frame_width=2, frame_color=color.new(color.gray, 0),
             bgcolor=color.new(color.black, 0))
    // advance any open simulated trades — fills modelled like the real engine:
    //   entry  = signal close ± slippage (market, adverse)
    //   TP hit = exact TP level (limit orders are NOT slipped)
    //   SL/BE  = stop level ± slippage (stop orders ARE slipped, adverse)
    //   EOD    = bar close ± slippage (market, adverse)
    // P&L expressed in R multiples: 1R = initial |entry−SL| × pointvalue (fixed at entry).
    // Commission (2×) and slippage are subtracted in dollar terms then converted to R.
    if opt_open_count > 0
        float _slip = i_slippage * syminfo.mintick
        for k = 0 to N_COMBOS - 1
            if array.get(a_open, k)
                bool  _isl   = array.get(a_long, k)
                float _e     = array.get(a_entry2, k)
                float _ef    = array.get(a_efill, k)
                float _slk   = array.get(a_sl2, k)
                float _tpk   = array.get(a_tp2, k)
                float _rk    = array.get(a_risk, k)        // price pts of initial stop
                float _1R    = array.get(a_initR, k)       // 1R in dollars
                bool  _slhit = _isl ? low <= _slk : high >= _slk
                bool  _tphit = _isl ? high >= _tpk : low <= _tpk
                float _xfill = na
                if _slhit and _tphit
                    _xfill := _isl ? _slk - _slip : _slk + _slip
                else if _tphit
                    _xfill := _tpk
                else if _slhit
                    _xfill := _isl ? _slk - _slip : _slk + _slip
                if na(_xfill) and i_move_sl_to_be and not array.get(a_bedone, k)
                    bool _behit = _isl ? high >= _e + _rk : low <= _e - _rk
                    if _behit
                        array.set(a_sl2, k, _e)
                        array.set(a_bedone, k, true)
                if na(_xfill) and (et_hhmm >= 1645 or new_session)
                    _xfill := _isl ? close - _slip : close + _slip
                if not na(_xfill)
                    float _pts  = _isl ? _xfill - _ef : _ef - _xfill
                    float _net  = _pts * syminfo.pointvalue - 2.0 * i_commission
                    // convert net $ to R multiples (1R = initial risk in $)
                    float _netR = _1R > 0 ? _net / _1R : 0.0
                    array.set(a_trades, k, array.get(a_trades, k) + 1)
                    if _net > 0
                        array.set(a_wins, k, array.get(a_wins, k) + 1)
                    else
                        array.set(a_losses, k, array.get(a_losses, k) + 1)
                    array.set(a_sumR, k, array.get(a_sumR, k) + _netR)
                    float _eqR = array.get(a_equityR, k) + _netR
                    array.set(a_equityR, k, _eqR)
                    float _pkR = math.max(array.get(a_peakR, k), _eqR)
                    array.set(a_peakR,  k, _pkR)
                    array.set(a_maxddR, k, math.max(array.get(a_maxddR, k), _pkR - _eqR))
                    array.set(a_open,   k, false)
                    opt_open_count := opt_open_count - 1

    // open a fresh sim per combo on a real entry — tick-snap SL/TP to the order
    // grid (the real engine rounds order prices) and slip the entry fill.
    if opt_fire
        float _mt   = syminfo.mintick
        float _slip = i_slippage * _mt
        float _efl  = opt_islong ? opt_entry + _slip : opt_entry - _slip
        for k = 0 to N_COMBOS - 1
            int   _isl   = int(k / N_TP)
            int   _itp   = k % N_TP
            float _slm   = 0.2 * (_isl + 1)
            float _tpm   = 0.2 * (_itp + 1)
            float _slraw = opt_islong ? opt_entry - _slm*opt_R : opt_entry + _slm*opt_R
            float _tpraw = opt_islong ? opt_entry + _tpm*opt_R : opt_entry - _tpm*opt_R
            float _slsn  = math.round(_slraw / _mt) * _mt
            float _tpsn  = math.round(_tpraw / _mt) * _mt
            float _riskPts = math.abs(opt_entry - _slsn)
            float _1Rdol   = _riskPts * syminfo.pointvalue  // 1R in dollars, fixed at entry
            array.set(a_open,   k, true)
            array.set(a_entry2, k, opt_entry)
            array.set(a_efill,  k, _efl)
            array.set(a_long,   k, opt_islong)
            array.set(a_risk,   k, _riskPts)
            array.set(a_initR,  k, _1Rdol)
            array.set(a_bedone, k, false)
            array.set(a_sl2, k, _slsn)
            array.set(a_tp2, k, _tpsn)
        opt_open_count := N_COMBOS

    // Repopulate the scoreboard on the last bar OR the end of confirmed history,
    // so it shows reliably on live charts too (not only right after a bar close).
    if barstate.islast or barstate.islastconfirmedhistory
        // ── Step 1: compute per-cell metric values and find best eligible cell ──
        // All 3 metrics are always computed; the goal dropdown picks which drives coloring.
        // Sample gate: cell is eligible only if trades >= i_min_trades AND losses >= i_min_losses.
        float[] a_metric = array.new_float(N_COMBOS, na)
        int   _best_k = -1
        float _best_v = na
        float _grid_min = na
        float _grid_max = na

        for k = 0 to N_COMBOS - 1
            int   _n  = array.get(a_trades, k)
            int   _nl = array.get(a_losses, k)
            bool  _eligible = _n >= i_min_trades and _nl >= i_min_losses
            float _v = na
            if _eligible
                if i_goal == "Expectancy (R)"
                    _v := array.get(a_sumR, k) / _n
                else if i_goal == "Calmar (R)"
                    float _dd = array.get(a_maxddR, k)
                    float _tot = array.get(a_equityR, k)
                    _v := _dd > 0 ? _tot / _dd : (_tot > 0 ? 1e9 : na)
                else  // Win Rate %
                    _v := 100.0 * array.get(a_wins, k) / _n
            array.set(a_metric, k, _v)
            if not na(_v)
                _grid_min := na(_grid_min) ? _v : math.min(_grid_min, _v)
                _grid_max := na(_grid_max) ? _v : math.max(_grid_max, _v)
                if na(_best_v) or _v > _best_v
                    _best_v := _v
                    _best_k := k

        // ── Step 2: header ───────────────────────────────────────────────────────
        int    _bsl = _best_k >= 0 ? int(_best_k / N_TP) : 0
        int    _btp = _best_k >= 0 ? _best_k % N_TP      : 0
        string _hdr = "GOAL: " + i_goal + "\nBEST  SL×" + str.tostring(0.2*(_bsl+1), "#.#") + "  TP×" + str.tostring(0.2*(_btp+1), "#.#")
        table.cell(opt_tbl, 0, 0, _hdr, text_size=size.small, text_color=color.white, bgcolor=color.new(color.blue, 0))
        for c = 1 to N_TP
            table.cell(opt_tbl, c, 0, "TP\n"+str.tostring(0.2*c, "#.#"), text_size=size.tiny, text_color=color.white, bgcolor=color.new(color.gray, 20))
        for r = 1 to N_SL
            table.cell(opt_tbl, 0, r, "SL "+str.tostring(0.2*r, "#.#"), text_size=size.tiny, text_color=color.white, bgcolor=color.new(color.gray, 20))

        // ── Step 3: draw cells with heatmap + plateau ★ ──────────────────────────
        float _range = (_grid_max - _grid_min) > 0 ? (_grid_max - _grid_min) : 1.0

        for r = 1 to N_SL
            for c = 1 to N_TP
                int   _k  = (r - 1) * N_TP + (c - 1)
                int   _n  = array.get(a_trades, _k)
                float _v  = array.get(a_metric, _k)
                bool  _eligible = _n >= i_min_trades and array.get(a_losses, _k) >= i_min_losses

                bool  _is_best = _k == _best_k and _best_k >= 0

                // cell display text — metric only for eligible cells; grey cells show trade count
                string _tx = na
                if not _eligible
                    _tx := "—\n(n=" + str.tostring(_n) + ")"
                else
                    if i_goal == "Expectancy (R)"
                        _tx := not na(_v) ? str.tostring(_v, "#.##") + "R" : "—"
                    else if i_goal == "Calmar (R)"
                        _tx := not na(_v) ? (_v >= 1e8 ? "∞" : str.tostring(_v, "#.##")) + "R" : "—"
                    else
                        _tx := not na(_v) ? str.tostring(_v, "#.#") + "%" : "—"
                if _is_best
                    _tx := "▶ " + _tx + " ◀"

                // plateau detection: cell is stable if all 4 orthogonal neighbors
                // are within 10% of its value (only for eligible cells)
                bool _stable = false
                if _eligible and not na(_v) and math.abs(_v) > 0
                    float _thresh = math.abs(_v) * 0.10
                    // neighbor indices (row ±1, col ±1 in grid → k ±N_TP, k ±1)
                    int _kU = (r - 2) * N_TP + (c - 1)  // up
                    int _kD =  r      * N_TP + (c - 1)  // down
                    int _kL = (r - 1) * N_TP + (c - 2)  // left
                    int _kR = (r - 1) * N_TP +  c        // right
                    bool _uOk = r == 1  or (not na(array.get(a_metric, _kU)) and math.abs(array.get(a_metric, _kU) - _v) <= _thresh)
                    bool _dOk = r == N_SL or (not na(array.get(a_metric, _kD)) and math.abs(array.get(a_metric, _kD) - _v) <= _thresh)
                    bool _lOk = c == 1  or (not na(array.get(a_metric, _kL)) and math.abs(array.get(a_metric, _kL) - _v) <= _thresh)
                    bool _rOk = c == N_TP or (not na(array.get(a_metric, _kR)) and math.abs(array.get(a_metric, _kR) - _v) <= _thresh)
                    _stable := _uOk and _dOk and _lOk and _rOk
                if _stable
                    _tx := _tx + " ★"

                // heatmap color: relative green→red gradient; grey for ineligible
                color _bg = na
                color _tc = na
                if not _eligible
                    _bg := color.new(color.gray, 0)
                    _tc := color.new(color.white, 60)
                else if na(_v)
                    _bg := color.new(color.gray, 0)
                    _tc := color.new(color.white, 60)
                else
                    // normalise 0→1 (best=1, worst=0)
                    float _norm = (_v - _grid_min) / _range
                    // blend: green (0,255,0) at norm=1, red (255,0,0) at norm=0 — fully opaque
                    int _r_ch = int(255 * (1.0 - _norm))
                    int _g_ch = int(255 * _norm)
                    _bg := color.rgb(_r_ch, _g_ch, 0, 0)
                    _tc := color.white

                // best cell for the chosen goal — override with a bright cyan highlight
                if _is_best
                    _bg := color.new(color.aqua, 0)
                    _tc := color.black

                table.cell(opt_tbl, c, r, _tx, text_size=size.tiny, text_color=_tc, bgcolor=_bg)

// Remove the optimizer table when the toggle is switched OFF
if not i_optimize and not na(opt_tbl)
    table.delete(opt_tbl)
    opt_tbl := na
