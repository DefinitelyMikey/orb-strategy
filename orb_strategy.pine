//@version=6

// ─────────────────────────────────────────────────────────────────────────────
//  INPUTS  (defined before strategy() so they can be used in its parameters)
// ─────────────────────────────────────────────────────────────────────────────

// ── Backtest Settings ────────────────────────────────────────────────────────
i_commission = input.float(
     2.00, "Commission Per Side ($)", minval=0, step=0.25,
     group="⚙️ Backtest Settings",
     tooltip="Reference only — Pine Script v6 requires constant values in strategy(). To apply commission in backtesting go to: Strategy Settings (gear icon) → Properties → Commission. Typical rates: Micro futures (MNQ/MES/MGC) $0.35–$0.60/side; Full-size (NQ/ES) $1.50–$2.50/side.")

i_slippage = input.int(
     1, "Slippage (Ticks)", minval=0,
     group="⚙️ Backtest Settings",
     tooltip="Reference only — Pine Script v6 requires constant values in strategy(). To apply slippage in backtesting go to: Strategy Settings (gear icon) → Properties → Slippage. NQ/MNQ: 1 tick = 0.25 pts. ES/MES: 1 tick = 0.25 pts. MGC: 1 tick = 0.10 pts.")

// ── Filters ──────────────────────────────────────────────────────────────────
i_min_body_atr = input.float(
     0.15, "Min B.O.S. Body Size (ATR Ratio)", minval=0, maxval=3, step=0.05,
     group="🔽 Filters",
     tooltip="The entry candle's body must be at least this multiple of ATR(14). Filters out doji and near-doji B.O.S. candles that have no directional conviction. 0 = disabled. Example: 0.15 = body must be ≥ 15% of ATR. Start with 0.10–0.20 and adjust per instrument.")

i_one_trade = input.bool(
     true, "One Trade At A Time",
     group="🔽 Filters",
     tooltip="When ON, an opposing signal is ignored while a position is open. Prevents simultaneously holding a long and a short. Recommended for consistent risk management.")

i_allow_reentry = input.bool(
     true, "Allow Re-entry After Stop",
     group="🔽 Filters",
     tooltip="When ON, a new B.O.S. entry is permitted after a stop loss — all setup conditions must be met fresh. When OFF, only one trade per setup direction per session. Use OFF for a strict one-trade-per-day rule; use ON to capitalize on multiple setups if they form.")

i_gap_filter = input.bool(
     false, "Enable Pre-market Gap Filter",
     group="🔽 Filters",
     tooltip="When ON, skips all trading on sessions where price gaps more than the set threshold from the prior day's close at the 8:00 AM open. Large overnight gaps produce extreme ORB ranges that distort signal quality.")

i_max_gap_pct = input.float(
     0.5, "Max Allowable Gap (%)", minval=0.1, maxval=10, step=0.1,
     group="🔽 Filters",
     tooltip="Maximum gap (%) between prior close and 8:00 AM ET open. If the gap exceeds this, no trades are taken that session. Only active when the Gap Filter is enabled. NQ/MNQ: try 0.3–0.5%. ES/MES: try 0.2–0.4%.")

// ── Colors ───────────────────────────────────────────────────────────────────
i_orb_color = input.color(
     color.new(color.blue, 80), "ORB Box",
     group="🎨 Colors",
     tooltip="Background fill color for the Opening Range box drawn on the 8:00 AM ET candle.")

i_mid_color = input.color(
     color.new(color.blue, 0), "ORB Midpoint Line",
     group="🎨 Colors",
     tooltip="Color of the dashed midpoint line through the ORB range. Price retracing to this level qualifies the setup as A+ grade.")

i_bos_color = input.color(
     color.new(color.orange, 0), "B.O.S. Level Line",
     group="🎨 Colors",
     tooltip="Color of the dashed Break of Structure level — the low/high of the most recent black→blue (sell) or blue→black (buy) candle pair. A body close through this line triggers entry.")

i_entry_color = input.color(
     color.new(color.white, 0), "Entry Line",
     group="🎨 Colors",
     tooltip="Horizontal line drawn at the entry price when a trade opens.")

i_sl_color = input.color(
     color.new(color.red, 0), "Stop Loss Line",
     group="🎨 Colors",
     tooltip="Horizontal line at the stop loss level. Moves to entry (breakeven) once the 1R target is hit.")

i_tp_color = input.color(
     color.new(color.lime, 0), "Take Profit Lines",
     group="🎨 Colors",
     tooltip="Solid line = 2R final target. Dotted line = 1R breakeven trigger level.")

// ── Reference Lines ───────────────────────────────────────────────────────────
i_show_vwap = input.bool(
     false, "Show VWAP",
     group="📊 Reference Lines",
     tooltip="Displays the Volume Weighted Average Price for the current session. Stronger B.O.S. signals: shorts firing below VWAP, longs above VWAP. Use as confluence — not a filter — unless you choose to add one.")

i_vwap_color = input.color(
     color.new(color.purple, 0), "VWAP Color",
     group="📊 Reference Lines")

i_show_pdhl = input.bool(
     false, "Show Prior Day High / Low",
     group="📊 Reference Lines",
     tooltip="Plots the prior trading session's high and low as step lines. These are major institutional reference levels — price frequently targets them before reversing. B.O.S. signals that align with a PDH/PDL test carry higher conviction.")

i_pdh_color = input.color(
     color.new(color.gray, 30), "Prior Day High Color",
     group="📊 Reference Lines")

i_pdl_color = input.color(
     color.new(color.gray, 30), "Prior Day Low Color",
     group="📊 Reference Lines")

// ─────────────────────────────────────────────────────────────────────────────
//  STRATEGY DECLARATION
// ─────────────────────────────────────────────────────────────────────────────
strategy(
    title                   = "8AM ORB Strategy [MNQ/NQ/ES/MES/MGC]",
    shorttitle              = "ORB",
    overlay                 = true,
    process_orders_on_close = true,
    default_qty_type        = strategy.fixed,
    default_qty_value       = 1
)

// ─────────────────────────────────────────────────────────────────────────────
//  HELPERS
// ─────────────────────────────────────────────────────────────────────────────
LOOKBACK   = 100  // bars to scan back for candle pair

// Eastern Time accessors
et_hour    = hour  (time, "America/New_York")
et_minute  = minute(time, "America/New_York")

// Candle anatomy
is_bearish  = close < open   // "black" candle
is_bullish  = close > open   // "blue" candle
body_high_  = math.max(open, close)
body_low_   = math.min(open, close)
body_size_  = body_high_ - body_low_
atr14       = ta.atr(14)

// Instrument detection
is_mgc = str.contains(syminfo.ticker, "MGC")

// ─────────────────────────────────────────────────────────────────────────────
//  ALWAYS-ON SECURITY CALLS  (must be at top level, not inside if blocks)
// ─────────────────────────────────────────────────────────────────────────────
prior_close_d             = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_off)
[pdh_val, pdl_val]        = request.security(syminfo.tickerid, "D", [high[1], low[1]], lookahead=barmerge.lookahead_off)

// ─────────────────────────────────────────────────────────────────────────────
//  SESSION RESET  (futures new session starts at 18:00 ET)
// ─────────────────────────────────────────────────────────────────────────────
new_session = et_hour == 18 and et_minute == 0

// ORB state
var float orb_high = na
var float orb_low  = na
var float orb_mid  = na
var bool  orb_set  = false

// Setup state — persists across trades within same session
var bool  sell_broken       = false  // body closed below ORB low this session
var bool  buy_broken        = false  // body closed above ORB high this session
var bool  sell_invalidated  = false  // body closed above ORB high → sell void
var bool  buy_invalidated   = false  // body closed below ORB low → buy void
var bool  sell_retrace_done = false  // after sell break, wick touched back into ORB zone
var bool  buy_retrace_done  = false  // after buy break, wick touched back into ORB zone
var int   sell_broken_bar   = na     // bar_index where sell_broken first flipped true
var int   buy_broken_bar    = na     // bar_index where buy_broken first flipped true

// Session trade counters
var int   sell_trades  = 0
var int   buy_trades   = 0
var bool  gap_session  = false

// Active trade state
var float t_entry = na
var float t_sl    = na
var float t_tp1   = na   // 1R — breakeven trigger
var float t_tp2   = na   // 2R — final target
var string t_dir  = na   // "short" | "long"
var bool  t_be    = false // true once breakeven triggered

if new_session
    orb_high          := na
    orb_low           := na
    orb_mid           := na
    orb_set           := false
    sell_broken       := false
    buy_broken        := false
    sell_invalidated  := false
    buy_invalidated   := false
    sell_retrace_done := false
    buy_retrace_done  := false
    sell_broken_bar   := na
    buy_broken_bar    := na
    sell_trades       := 0
    buy_trades        := 0
    gap_session       := false

// ─────────────────────────────────────────────────────────────────────────────
//  ORB DETECTION  (8:00 AM ET bar close)
// ─────────────────────────────────────────────────────────────────────────────
is_orb_bar = et_hour == 8 and et_minute == 0

if is_orb_bar and not orb_set
    orb_high := high
    orb_low  := low
    orb_mid  := (high + low) / 2
    orb_set  := true
    // Gap filter: compare 8 AM open to prior day close
    if i_gap_filter and not na(prior_close_d) and prior_close_d != 0
        float gap_pct = math.abs(open - prior_close_d) / prior_close_d * 100
        if gap_pct > i_max_gap_pct
            gap_session := true

// ─────────────────────────────────────────────────────────────────────────────
//  SETUP STATE UPDATES
// ─────────────────────────────────────────────────────────────────────────────
if orb_set and not is_orb_bar and not gap_session
    // Break detection: body (not wick) crosses ORB boundary
    // Capture bar_index on first flip only — gates retrace to a strictly later bar
    // so the breakout candle itself can never count as its own retracement
    if not sell_invalidated and not sell_broken and body_low_ < orb_low
        sell_broken     := true
        sell_broken_bar := bar_index
    if not buy_invalidated and not buy_broken and body_high_ > orb_high
        buy_broken     := true
        buy_broken_bar := bar_index

    // Retrace: after a break, on a LATER bar, any wick touching back into ORB zone counts
    // A+ setup = wick reaches orb_mid; Valid setup = wick reaches orb_low/orb_high
    if sell_broken and not sell_retrace_done and bar_index > sell_broken_bar and high >= orb_low
        sell_retrace_done := true
    if buy_broken and not buy_retrace_done and bar_index > buy_broken_bar and low <= orb_high
        buy_retrace_done := true

    // Invalidation: pre-entry only — body close beyond the opposing ORB level
    if strategy.position_size == 0
        if sell_broken and body_high_ > orb_high
            sell_broken      := false
            sell_invalidated := true
        if buy_broken and body_low_ < orb_low
            buy_broken      := false
            buy_invalidated := true

// ─────────────────────────────────────────────────────────────────────────────
//  STRUCTURE LEVEL CALCULATION
//  Scan from bar[1] backward — current bar (bar[0]) is the potential B.O.S. candle,
//  so the pair must be formed entirely in prior bars.
// ─────────────────────────────────────────────────────────────────────────────

// SELL structure: most recent [black → blue] pair
// → find most recent blue, then most recent black before it
// → level = min(low of black, low of blue)
float sell_struct = na
int   s_blue_at   = -1
for i = 1 to math.min(bar_index, LOOKBACK)
    bool c_bull = close[i] > open[i]
    bool c_bear = close[i] < open[i]
    if s_blue_at == -1
        if c_bull
            s_blue_at := i
    else
        if c_bear
            sell_struct := math.min(low[i], low[s_blue_at])
            break

// BUY structure: most recent [blue → black] pair
// → find most recent black, then most recent blue before it
// → level = max(high of blue, high of black)
float buy_struct  = na
int   b_black_at  = -1
for i = 1 to math.min(bar_index, LOOKBACK)
    bool c_bull = close[i] > open[i]
    bool c_bear = close[i] < open[i]
    if b_black_at == -1
        if c_bear
            b_black_at := i
    else
        if c_bull
            buy_struct := math.max(high[i], high[b_black_at])
            break

// ─────────────────────────────────────────────────────────────────────────────
//  ENTRY CONDITIONS
// ─────────────────────────────────────────────────────────────────────────────
// MGC: no new entries at or after 12:00 PM ET; max 2 trades per direction per session
time_ok      = not is_mgc or et_hour < 12
body_size_ok = i_min_body_atr == 0 or body_size_ >= i_min_body_atr * atr14
no_pos       = strategy.position_size == 0

mgc_sell_ok  = not is_mgc or sell_trades < 2
mgc_buy_ok   = not is_mgc or buy_trades  < 2
reentry_sell = i_allow_reentry or sell_trades == 0
reentry_buy  = i_allow_reentry or buy_trades  == 0
ota_ok       = not i_one_trade or no_pos

// SELL signal: bearish B.O.S. candle closes body below sell structure level
bool sell_setup  = sell_broken and sell_retrace_done and not sell_invalidated
bool sell_bos    = not na(sell_struct) and is_bearish and body_low_ < sell_struct
bool sell_guards = body_size_ok and time_ok and no_pos and ota_ok and mgc_sell_ok and reentry_sell and not gap_session
bool sell_signal = sell_setup and sell_bos and sell_guards

// BUY signal: bullish B.O.S. candle closes body above buy structure level
bool buy_setup   = buy_broken and buy_retrace_done and not buy_invalidated
bool buy_bos     = not na(buy_struct) and is_bullish and body_high_ > buy_struct
bool buy_guards  = body_size_ok and time_ok and no_pos and ota_ok and mgc_buy_ok and reentry_buy and not gap_session
bool buy_signal  = buy_setup and buy_bos and buy_guards

// ─────────────────────────────────────────────────────────────────────────────
//  ENTRIES
//  Entry  = close of B.O.S. candle (= body low for bearish, body high for bullish)
//  SL     = open  of B.O.S. candle (= body high for bearish, body low for bullish)
//  Risk R = |close − open| of B.O.S. candle
// ─────────────────────────────────────────────────────────────────────────────
if sell_signal
    t_entry := close
    t_sl    := open
    float _r = t_sl - t_entry   // positive: open > close for bearish
    t_tp1   := t_entry - _r     // 1R below entry
    t_tp2   := t_entry - 2 * _r // 2R below entry
    t_dir   := "short"
    t_be    := false
    sell_trades += 1
    strategy.entry("Short", strategy.short)
    strategy.exit("SX", from_entry="Short", stop=t_sl, limit=t_tp2)

if buy_signal
    t_entry := close
    t_sl    := open
    float _r = t_entry - t_sl   // positive: close > open for bullish
    t_tp1   := t_entry + _r     // 1R above entry
    t_tp2   := t_entry + 2 * _r // 2R above entry
    t_dir   := "long"
    t_be    := false
    buy_trades += 1
    strategy.entry("Long", strategy.long)
    strategy.exit("LX", from_entry="Long", stop=t_sl, limit=t_tp2)

// ─────────────────────────────────────────────────────────────────────────────
//  BREAKEVEN MANAGEMENT
//  When price hits 1R, update exit to move SL to entry (risk-free runner to 2R)
// ─────────────────────────────────────────────────────────────────────────────
if not t_be and not na(t_tp1)
    if t_dir == "short" and low <= t_tp1
        strategy.exit("SX", from_entry="Short", stop=t_entry, limit=t_tp2)
        t_be := true
    if t_dir == "long" and high >= t_tp1
        strategy.exit("LX", from_entry="Long", stop=t_entry, limit=t_tp2)
        t_be := true

// Reset trade state when flat
if no_pos and not na(t_dir)
    t_dir   := na
    t_entry := na
    t_sl    := na
    t_tp1   := na
    t_tp2   := na
    t_be    := false

// ─────────────────────────────────────────────────────────────────────────────
//  VISUALS
// ─────────────────────────────────────────────────────────────────────────────

// ── ORB Box + Midpoint (8:00 AM candle only — stops at 8:15 AM)
var box  _orb_box  = na
var line _mid_line = na
if is_orb_bar
    box.delete(_orb_box)
    line.delete(_mid_line)
    _orb_box  := box.new(bar_index, orb_high, bar_index + 1, orb_low,
         border_color=i_orb_color, bgcolor=i_orb_color, extend=extend.none)
    _mid_line := line.new(bar_index, orb_mid, bar_index + 1, orb_mid,
         color=i_mid_color, style=line.style_dashed, width=1)

// ── B.O.S. Level Lines (live while setup is active, extend right until invalidated)
var line _sell_bos_line = na
var line _buy_bos_line  = na

// Sell B.O.S. level
if sell_broken and not sell_invalidated and not na(sell_struct) and not sell_signal
    if na(_sell_bos_line)
        _sell_bos_line := line.new(bar_index, sell_struct, bar_index + 1, sell_struct,
             color=i_bos_color, style=line.style_dashed, width=1, extend=extend.right)
    else
        line.set_y1(_sell_bos_line, sell_struct)
        line.set_y2(_sell_bos_line, sell_struct)
else
    line.delete(_sell_bos_line)
    _sell_bos_line := na

// Buy B.O.S. level
if buy_broken and not buy_invalidated and not na(buy_struct) and not buy_signal
    if na(_buy_bos_line)
        _buy_bos_line := line.new(bar_index, buy_struct, bar_index + 1, buy_struct,
             color=i_bos_color, style=line.style_dashed, width=1, extend=extend.right)
    else
        line.set_y1(_buy_bos_line, buy_struct)
        line.set_y2(_buy_bos_line, buy_struct)
else
    line.delete(_buy_bos_line)
    _buy_bos_line := na

// ── Entry / SL / TP Lines (drawn on entry, extend 80 bars)
var line _entry_line = na
var line _sl_line    = na
var line _tp1_line   = na
var line _tp2_line   = na

if sell_signal or buy_signal
    line.delete(_entry_line)
    line.delete(_sl_line)
    line.delete(_tp1_line)
    line.delete(_tp2_line)
    _entry_line := line.new(bar_index, t_entry, bar_index + 80, t_entry,
         color=i_entry_color, style=line.style_solid,  width=1)
    _sl_line    := line.new(bar_index, t_sl,    bar_index + 80, t_sl,
         color=i_sl_color,    style=line.style_solid,  width=1)
    _tp1_line   := line.new(bar_index, t_tp1,   bar_index + 80, t_tp1,
         color=i_tp_color,    style=line.style_dotted, width=1)
    _tp2_line   := line.new(bar_index, t_tp2,   bar_index + 80, t_tp2,
         color=i_tp_color,    style=line.style_solid,  width=1)

// Move SL line to breakeven when triggered
if t_be and not na(_sl_line)
    line.set_y1(_sl_line, t_entry)
    line.set_y2(_sl_line, t_entry)

// ── VWAP
vwap_val = i_show_vwap ? ta.vwap(hlc3) : na
plot(vwap_val, "VWAP", color=i_vwap_color, linewidth=1)

// ── Prior Day High / Low
plot(i_show_pdhl ? pdh_val : na, "PDH", color=i_pdh_color, linewidth=1, style=plot.style_stepline)
plot(i_show_pdhl ? pdl_val : na, "PDL", color=i_pdl_color, linewidth=1, style=plot.style_stepline)

// ── Entry / Exit labels on chart
plotshape(sell_signal, "Short Entry", style=shape.triangledown, location=location.abovebar, color=i_sl_color,    size=size.small)
plotshape(buy_signal,  "Long Entry",  style=shape.triangleup,   location=location.belowbar, color=i_entry_color, size=size.small)
