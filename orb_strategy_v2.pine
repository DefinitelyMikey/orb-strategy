//@version=6

// ═════════════════════════════════════════════════════════════════════════════
//  ORB Strategy V2  |  Pine Script v6
//  Chart     : 5-minute
//  ORB Source: 15-minute (via request.security)
//  Session   : 8:00 AM ET open  |  Reset: 18:00 ET
//  Instruments: NQ, MNQ, ES, MES, YM, MYM, GC, MGC
//
//  Entry logic:
//    1. Breakout validated: C1 close outside ORB + wick cleared (last candle
//       pair extreme), C2+ full body outside ORB
//    2. Pullback: price returns toward ORB zone, sweeps prior swing (liquidity)
//    3. BOS: bull/bear body close beyond most recent pullback pivot
//    Grade assigned at entry (A/B/C/2B/2C) based on pullback depth + liq sweep
//
//  Trade mgmt: SL = BOS candle body open | TP = 2:1 RR | BE at 1:1 RR
//  Max entries per session: user-adjustable per instrument (default 2)
// ═════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────────────────
//  INPUTS  (defined before strategy() so they're available at declaration)
// ─────────────────────────────────────────────────────────────────────────────

// ── Backtest Settings ────────────────────────────────────────────────────────
i_commission = input.float(
    2.00, "Commission Per Side ($)", minval=0, step=0.25,
    group="⚙️ Backtest Settings",
    tooltip="Reference only — Pine Script v6 requires constant values in strategy(). Set via Strategy Settings → Properties → Commission.")

i_slippage = input.int(
    1, "Slippage (Ticks)", minval=0,
    group="⚙️ Backtest Settings",
    tooltip="Reference only — set via Strategy Settings → Properties → Slippage.")

// ── Instrument Rules ─────────────────────────────────────────────────────────
i_max_nq  = input.int(2,    "NQ  — Max Trades/Session", minval=1, group="📊 Instrument Rules")
i_cut_nq  = input.int(1600, "NQ  — Time Cutoff (HHMM ET)", minval=0, maxval=2359, group="📊 Instrument Rules")
i_max_mnq = input.int(2,    "MNQ — Max Trades/Session", minval=1, group="📊 Instrument Rules")
i_cut_mnq = input.int(1600, "MNQ — Time Cutoff (HHMM ET)", minval=0, maxval=2359, group="📊 Instrument Rules")
i_max_es  = input.int(2,    "ES  — Max Trades/Session", minval=1, group="📊 Instrument Rules")
i_cut_es  = input.int(1600, "ES  — Time Cutoff (HHMM ET)", minval=0, maxval=2359, group="📊 Instrument Rules")
i_max_mes = input.int(2,    "MES — Max Trades/Session", minval=1, group="📊 Instrument Rules")
i_cut_mes = input.int(1600, "MES — Time Cutoff (HHMM ET)", minval=0, maxval=2359, group="📊 Instrument Rules")
i_max_ym  = input.int(2,    "YM  — Max Trades/Session", minval=1, group="📊 Instrument Rules")
i_cut_ym  = input.int(1600, "YM  — Time Cutoff (HHMM ET)", minval=0, maxval=2359, group="📊 Instrument Rules")
i_max_mym = input.int(2,    "MYM — Max Trades/Session", minval=1, group="📊 Instrument Rules")
i_cut_mym = input.int(1600, "MYM — Time Cutoff (HHMM ET)", minval=0, maxval=2359, group="📊 Instrument Rules")
i_max_gc  = input.int(2,    "GC  — Max Trades/Session", minval=1, group="📊 Instrument Rules")
i_cut_gc  = input.int(1600, "GC  — Time Cutoff (HHMM ET)", minval=0, maxval=2359, group="📊 Instrument Rules")
i_max_mgc = input.int(2,    "MGC — Max Trades/Session", minval=1, group="📊 Instrument Rules")
i_cut_mgc = input.int(1600, "MGC — Time Cutoff (HHMM ET)", minval=0, maxval=2359, group="📊 Instrument Rules")

// ── ORB Settings ─────────────────────────────────────────────────────────────
i_orb_end = input.int(
    1700, "ORB Box End Time (HHMM ET)", minval=800, maxval=2359,
    group="📐 ORB Settings",
    tooltip="ORB box and midpoint line extend rightward until this time. Default 17:00 ET.")

// ── Setup Grades ─────────────────────────────────────────────────────────────
i_grade_a  = input.bool(true, "Enable Grade A",  group="🏆 Setup Grades",
    tooltip="Deep pullback (through full ORB zone) + liquidity sweep. Highest quality.")
i_grade_b  = input.bool(true, "Enable Grade B",  group="🏆 Setup Grades",
    tooltip="Mid pullback (ORB midpoint touch) + liquidity sweep.")
i_grade_c  = input.bool(true, "Enable Grade C",  group="🏆 Setup Grades",
    tooltip="Shallow pullback (ORB boundary touch) + liquidity sweep.")
i_grade_2b = input.bool(true, "Enable Grade 2B", group="🏆 Setup Grades",
    tooltip="Mid pullback, no liquidity sweep.")
i_grade_2c = input.bool(true, "Enable Grade 2C", group="🏆 Setup Grades",
    tooltip="Shallow pullback, no liquidity sweep.")

// ── Visuals ───────────────────────────────────────────────────────────────────
i_show_swing      = input.bool(true,  "Show Swing High/Low Markers", group="👁 Visuals")
i_show_grade_text = input.bool(true,  "Show Grade Text on Entry",    group="👁 Visuals")
i_pivot_lookback  = input.int(10, "Swing Pivot Lookback (bars each side)", minval=1, maxval=50,
    group="👁 Visuals",
    tooltip="Bars required on each side of a pivot to confirm a swing high/low. Higher = fewer, higher-quality swings. Default 10.")
i_show_volume  = input.bool(false, "Show Volume Context",         group="👁 Visuals")
i_show_vwap    = input.bool(false, "Show VWAP",                   group="👁 Visuals")
i_show_pdhl    = input.bool(false, "Show Prior Day High/Low",     group="👁 Visuals")
i_vol_lookback = input.int(20, "Volume Avg Lookback (bars)", minval=5, maxval=100,
    group="👁 Visuals",
    tooltip="Bars used to compute average volume for context display.")

// ── Colors ────────────────────────────────────────────────────────────────────
i_col_orb_box  = input.color(color.new(color.blue,   80), "ORB Box",        group="🎨 Colors")
i_col_orb_mid  = input.color(color.new(color.blue,   30), "ORB Midpoint",   group="🎨 Colors")
i_col_swing_h  = input.color(color.new(color.lime,    0), "Swing High",     group="🎨 Colors")
i_col_swing_l  = input.color(color.new(color.red,     0), "Swing Low",      group="🎨 Colors")
i_col_grade_a  = input.color(color.new(color.green,   0), "Grade A Label",  group="🎨 Colors")
i_col_grade_b  = input.color(color.new(color.lime,    0), "Grade B Label",  group="🎨 Colors")
i_col_grade_c  = input.color(color.new(color.yellow,  0), "Grade C Label",  group="🎨 Colors")
i_col_grade_2b = input.color(color.new(color.orange,  0), "Grade 2B Label", group="🎨 Colors")
i_col_grade_2c = input.color(color.new(color.red,     0), "Grade 2C Label", group="🎨 Colors")
i_col_vwap     = input.color(color.new(color.purple,  0), "VWAP",           group="🎨 Colors")
i_col_pdhl     = input.color(color.new(color.gray,    0), "Prior Day H/L",  group="🎨 Colors")
i_col_vol_hi   = input.color(color.new(color.yellow,  0), "Volume Spike",   group="🎨 Colors")

strategy("ORB Strategy V2", overlay=true, process_orders_on_close=true,
    pyramiding=2, max_bars_back=500,
    default_qty_type=strategy.fixed, default_qty_value=1)

// ─────────────────────────────────────────────────────────────────────────────
//  TIME UTILITIES
// ─────────────────────────────────────────────────────────────────────────────

int et_hour   = hour(time,   "America/New_York")
int et_minute = minute(time, "America/New_York")
int et_hhmm   = et_hour * 100 + et_minute

bool is_orb_bar  = et_hour == 8 and et_minute == 0
bool new_session = et_hour == 18 and et_minute == 0

// ─────────────────────────────────────────────────────────────────────────────
//  INSTRUMENT DETECTION + PER-INSTRUMENT LIMITS
// ─────────────────────────────────────────────────────────────────────────────

bool is_mnq = str.contains(syminfo.ticker, "MNQ")
bool is_nq  = str.contains(syminfo.ticker, "NQ")  and not is_mnq
bool is_mes = str.contains(syminfo.ticker, "MES")
bool is_es  = str.contains(syminfo.ticker, "ES")  and not is_mes
bool is_mym = str.contains(syminfo.ticker, "MYM")
bool is_ym  = str.contains(syminfo.ticker, "YM")  and not is_mym
bool is_mgc = str.contains(syminfo.ticker, "MGC")
bool is_gc  = str.contains(syminfo.ticker, "GC")  and not is_mgc

int inst_max = is_nq  ? i_max_nq  : is_mnq ? i_max_mnq :
               is_es  ? i_max_es  : is_mes  ? i_max_mes :
               is_ym  ? i_max_ym  : is_mym  ? i_max_mym :
               is_gc  ? i_max_gc  : is_mgc  ? i_max_mgc : 2

int inst_cut = is_nq  ? i_cut_nq  : is_mnq ? i_cut_mnq :
               is_es  ? i_cut_es  : is_mes  ? i_cut_mes :
               is_ym  ? i_cut_ym  : is_mym  ? i_cut_mym :
               is_gc  ? i_cut_gc  : is_mgc  ? i_cut_mgc : 1600

bool time_ok = et_hhmm < inst_cut

// ─────────────────────────────────────────────────────────────────────────────
//  15M ORB DATA  (request.security fetches 15m OHLC in 5m chart context)
// ─────────────────────────────────────────────────────────────────────────────

float orb_high_raw = request.security(syminfo.tickerid, "15",
    ta.valuewhen(
        hour(time, "America/New_York") == 8 and minute(time, "America/New_York") == 0,
        high, 0),
    barmerge.gaps_off, barmerge.lookahead_off)

float orb_low_raw  = request.security(syminfo.tickerid, "15",
    ta.valuewhen(
        hour(time, "America/New_York") == 8 and minute(time, "America/New_York") == 0,
        low, 0),
    barmerge.gaps_off, barmerge.lookahead_off)

// ─────────────────────────────────────────────────────────────────────────────
//  HELPER FUNCTIONS
// ─────────────────────────────────────────────────────────────────────────────

// Grade string from pullback depth + liquidity ("" = invalid or disabled)
grade_str(int depth, bool liq) =>
    string _g = ""
    if depth == 3
        _g := liq ? "A" : ""
    else if depth == 2
        _g := liq ? "B" : "2B"
    else if depth == 1
        _g := liq ? "C" : "2C"
    bool _ea  = _g == "A"  and i_grade_a
    bool _eb  = _g == "B"  and i_grade_b
    bool _ec  = _g == "C"  and i_grade_c
    bool _e2b = _g == "2B" and i_grade_2b
    bool _e2c = _g == "2C" and i_grade_2c
    bool _en  = _ea or _eb or _ec or _e2b or _e2c
    _en ? _g : ""

// Color for a grade string
grade_col(string g) =>
    color _c = color.gray
    if g == "A"
        _c := i_col_grade_a
    else if g == "B"
        _c := i_col_grade_b
    else if g == "C"
        _c := i_col_grade_c
    else if g == "2B"
        _c := i_col_grade_2b
    else if g == "2C"
        _c := i_col_grade_2c
    _c

// ─────────────────────────────────────────────────────────────────────────────
//  STATE VARIABLES
// ─────────────────────────────────────────────────────────────────────────────

// ORB
var bool  orb_set  = false
var float orb_high = na
var float orb_low  = na
var float orb_mid  = na

// Breakout validation
var bool brk_c1_long    = false
var bool brk_c1_short   = false
var bool brk_c2_long    = false
var bool brk_c2_short   = false
var bool brk_valid_long  = false
var bool brk_valid_short = false

// Pullback depth: 0=none, 1=shallow (boundary touch), 2=mid, 3=deep (through ORB)
var int pull_long  = 0
var int pull_short = 0

// Liquidity sweep flag
var bool liq_long  = false
var bool liq_short = false

// Swing levels (3-bar pivot, updated each bar after ORB set)
var float swing_high = na
var float swing_low  = na

// BOS trigger levels (most recent pivot formed during pullback phase)
var float bos_lvl_long  = na
var float bos_lvl_short = na

// Session trade counter
var int entry_count = 0

// BE management — slot 1 and slot 2 (max 2 simultaneous via pyramiding=2)
var float  s1_entry   = na
var float  s1_sl      = na
var float  s1_tp      = na
var bool   s1_be_done = false
var bool   s1_is_long = true
var string s1_id      = ""

var float  s2_entry   = na
var float  s2_sl      = na
var float  s2_tp      = na
var bool   s2_be_done = false
var bool   s2_is_long = true
var string s2_id      = ""

// ORB visual objects (persist for box extending)
var box  orb_box_obj  = na
var line orb_mid_line = na

// ─────────────────────────────────────────────────────────────────────────────
//  SESSION RESET  (18:00 ET — futures new session)
// ─────────────────────────────────────────────────────────────────────────────

if new_session
    orb_set          := false
    orb_high         := na
    orb_low          := na
    orb_mid          := na
    brk_c1_long      := false
    brk_c1_short     := false
    brk_c2_long      := false
    brk_c2_short     := false
    brk_valid_long   := false
    brk_valid_short  := false
    pull_long        := 0
    pull_short       := 0
    liq_long         := false
    liq_short        := false
    swing_high       := na
    swing_low        := na
    bos_lvl_long     := na
    bos_lvl_short    := na
    entry_count      := 0
    s1_entry         := na
    s1_sl            := na
    s1_tp            := na
    s1_be_done       := false
    s1_id            := ""
    s2_entry         := na
    s2_sl            := na
    s2_tp            := na
    s2_be_done       := false
    s2_id            := ""
    orb_box_obj      := na
    orb_mid_line     := na

// ─────────────────────────────────────────────────────────────────────────────
//  ORB LATCH  (8:00 AM ET bar — set once per session)
// ─────────────────────────────────────────────────────────────────────────────

if is_orb_bar and not orb_set and not na(orb_high_raw) and not na(orb_low_raw)
    orb_set  := true
    orb_high := orb_high_raw
    orb_low  := orb_low_raw
    orb_mid  := (orb_high_raw + orb_low_raw) / 2

// ─────────────────────────────────────────────────────────────────────────────
//  SWING HIGH / LOW  (3-bar pivot)
// ─────────────────────────────────────────────────────────────────────────────

float _ph = ta.pivothigh(i_pivot_lookback, i_pivot_lookback)
float _pl = ta.pivotlow (i_pivot_lookback, i_pivot_lookback)
bool pivot_h = not na(_ph)
bool pivot_l = not na(_pl)

if orb_set and pivot_h
    swing_high := _ph
if orb_set and pivot_l
    swing_low  := _pl

// ─────────────────────────────────────────────────────────────────────────────
//  BREAKOUT VALIDATION
//  C1: close outside ORB AND clears last [green→red] (buy) or [red→green] (sell) pair extreme
//  C2+: full body (open AND close) outside ORB, on any bar after C1
// ─────────────────────────────────────────────────────────────────────────────

if orb_set and not is_orb_bar

    // ── C1 Long ──────────────────────────────────────────────────────────────
    if not brk_c1_long and close > orb_high
        float pair_ext = na
        for i = 1 to 50
            bool is_g = close[i + 1] > open[i + 1]
            bool is_r = close[i]     < open[i]
            if is_g and is_r
                pair_ext := math.max(high[i], high[i + 1])
                break
        if not na(pair_ext) and close > pair_ext
            brk_c1_long := true

    // ── C1 Short ─────────────────────────────────────────────────────────────
    if not brk_c1_short and close < orb_low
        float pair_ext = na
        for i = 1 to 50
            bool is_r = close[i + 1] < open[i + 1]
            bool is_g = close[i]     > open[i]
            if is_r and is_g
                pair_ext := math.min(low[i], low[i + 1])
                break
        if not na(pair_ext) and close < pair_ext
            brk_c1_short := true

    // ── C2+ Long: full body above ORB high ───────────────────────────────────
    if brk_c1_long and not brk_c2_long
        bool c2l = open > orb_high and close > orb_high
        if c2l
            brk_c2_long := true

    // ── C2+ Short: full body below ORB low ───────────────────────────────────
    if brk_c1_short and not brk_c2_short
        bool c2s = open < orb_low and close < orb_low
        if c2s
            brk_c2_short := true

    // ── Valid breakout flags ──────────────────────────────────────────────────
    if brk_c1_long  and brk_c2_long  and not brk_valid_long
        brk_valid_long  := true
    if brk_c1_short and brk_c2_short and not brk_valid_short
        brk_valid_short := true

// ─────────────────────────────────────────────────────────────────────────────
//  PULLBACK DEPTH + LIQUIDITY SWEEP
//  Depth 1 = shallow: wick touches ORB boundary edge
//  Depth 2 = mid    : wick touches ORB midpoint
//  Depth 3 = deep   : wick breaches through entire ORB zone
//  Liquidity        : wick sweeps the last confirmed session swing low (long)
//                     or swing high (short)
// ─────────────────────────────────────────────────────────────────────────────

if orb_set and not is_orb_bar

    // Long pullback (price retracing down after breaking above ORB high)
    if brk_valid_long
        if pull_long < 1 and low <= orb_high
            pull_long := 1
        if pull_long < 2 and low <= orb_mid
            pull_long := 2
        if pull_long < 3 and low <= orb_low
            pull_long := 3
        if not liq_long and not na(swing_low) and low <= swing_low
            liq_long := true

    // Short pullback (price retracing up after breaking below ORB low)
    if brk_valid_short
        if pull_short < 1 and high >= orb_low
            pull_short := 1
        if pull_short < 2 and high >= orb_mid
            pull_short := 2
        if pull_short < 3 and high >= orb_high
            pull_short := 3
        if not liq_short and not na(swing_high) and high >= swing_high
            liq_short := true

// ─────────────────────────────────────────────────────────────────────────────
//  BOS LEVEL  (track most recent pivot that forms during pullback phase)
//  This becomes the structural level a BOS candle must close beyond for entry
// ─────────────────────────────────────────────────────────────────────────────

if brk_valid_long  and pull_long  > 0 and pivot_h
    bos_lvl_long  := high[1]
if brk_valid_short and pull_short > 0 and pivot_l
    bos_lvl_short := low[1]

// ─────────────────────────────────────────────────────────────────────────────
//  BOS ENTRY TRIGGER
// ─────────────────────────────────────────────────────────────────────────────

float body_high = math.max(open, close)
float body_low  = math.min(open, close)
bool  bull_bar  = close > open
bool  bear_bar  = close < open

string cur_grade_long  = grade_str(pull_long,  liq_long)
string cur_grade_short = grade_str(pull_short, liq_short)

bool buy_signal  = brk_valid_long  and pull_long  > 0 and not na(bos_lvl_long)  and
                   cur_grade_long  != "" and bull_bar  and body_high > bos_lvl_long  and
                   entry_count < inst_max and time_ok

bool sell_signal = brk_valid_short and pull_short > 0 and not na(bos_lvl_short) and
                   cur_grade_short != "" and bear_bar  and body_low  < bos_lvl_short and
                   entry_count < inst_max and time_ok

// ── Long entry ───────────────────────────────────────────────────────────────
if buy_signal
    float _r  = math.abs(close - open)
    float _sl = open
    float _tp = close + 2.0 * _r
    string _id = "L" + str.tostring(entry_count + 1)
    strategy.entry(_id, strategy.long)
    strategy.exit(_id + "x", _id, stop=_sl, limit=_tp)
    if na(s1_entry)
        s1_entry   := close
        s1_sl      := _sl
        s1_tp      := _tp
        s1_be_done := false
        s1_is_long := true
        s1_id      := _id
    else
        s2_entry   := close
        s2_sl      := _sl
        s2_tp      := _tp
        s2_be_done := false
        s2_is_long := true
        s2_id      := _id
    entry_count := entry_count + 1
    if i_show_grade_text
        label.new(bar_index, high + ta.atr(14) * 3.0, cur_grade_long,
            style=label.style_none, color=color.new(color.black, 100),
            textcolor=grade_col(cur_grade_long), size=size.large)

// ── Short entry ──────────────────────────────────────────────────────────────
if sell_signal
    float _r  = math.abs(close - open)
    float _sl = open
    float _tp = close - 2.0 * _r
    string _id = "S" + str.tostring(entry_count + 1)
    strategy.entry(_id, strategy.short)
    strategy.exit(_id + "x", _id, stop=_sl, limit=_tp)
    if na(s1_entry)
        s1_entry   := close
        s1_sl      := _sl
        s1_tp      := _tp
        s1_be_done := false
        s1_is_long := false
        s1_id      := _id
    else
        s2_entry   := close
        s2_sl      := _sl
        s2_tp      := _tp
        s2_be_done := false
        s2_is_long := false
        s2_id      := _id
    entry_count := entry_count + 1
    if i_show_grade_text
        label.new(bar_index, high + ta.atr(14) * 3.0, cur_grade_short,
            style=label.style_none, color=color.new(color.black, 100),
            textcolor=grade_col(cur_grade_short), size=size.large)

// ─────────────────────────────────────────────────────────────────────────────
//  BREAKEVEN MANAGEMENT  (move SL to entry when 1:1 RR reached)
// ─────────────────────────────────────────────────────────────────────────────

if not na(s1_entry) and not s1_be_done and s1_id != ""
    float _r  = math.abs(s1_entry - s1_sl)
    bool  hit = s1_is_long ? high >= s1_entry + _r : low <= s1_entry - _r
    if hit
        strategy.exit(s1_id + "x", s1_id, stop=s1_entry, limit=s1_tp)
        s1_be_done := true

if not na(s2_entry) and not s2_be_done and s2_id != ""
    float _r  = math.abs(s2_entry - s2_sl)
    bool  hit = s2_is_long ? high >= s2_entry + _r : low <= s2_entry - _r
    if hit
        strategy.exit(s2_id + "x", s2_id, stop=s2_entry, limit=s2_tp)
        s2_be_done := true

// ─────────────────────────────────────────────────────────────────────────────
//  POSITION CLOSE HANDLING  (BE stop-out or TP hit)
//  Clear slots and reset BOS level so re-entry can form a fresh setup
// ─────────────────────────────────────────────────────────────────────────────

bool pos_closed = strategy.position_size == 0 and
                  strategy.position_size[1] != 0 and
                  not new_session

if pos_closed
    s1_entry      := na
    s1_sl         := na
    s1_tp         := na
    s1_be_done    := false
    s1_id         := ""
    s2_entry      := na
    s2_sl         := na
    s2_tp         := na
    s2_be_done    := false
    s2_id         := ""
    bos_lvl_long  := na
    bos_lvl_short := na

// ─────────────────────────────────────────────────────────────────────────────
//  ORB VISUALS  (box + midpoint, extending to i_orb_end)
// ─────────────────────────────────────────────────────────────────────────────

if orb_set and is_orb_bar and na(orb_box_obj)
    orb_box_obj  := box.new(bar_index, orb_high, bar_index + 1, orb_low,
                             border_color=i_col_orb_box, bgcolor=i_col_orb_box)
    orb_mid_line := line.new(bar_index, orb_mid, bar_index + 1, orb_mid,
                              color=i_col_orb_mid, style=line.style_dashed, width=1)

if orb_set and not na(orb_box_obj) and et_hhmm <= i_orb_end
    box.set_right(orb_box_obj, bar_index + 1)
    line.set_x2(orb_mid_line, bar_index + 1)

// ─────────────────────────────────────────────────────────────────────────────
//  SWING MARKERS  (triangles offset above/below wick so they don't overlap)
// ─────────────────────────────────────────────────────────────────────────────

float tick_off = syminfo.mintick * 8

if i_show_swing and orb_set and pivot_h
    label.new(bar_index[i_pivot_lookback], _ph + tick_off, "▲",
        style=label.style_none, textcolor=i_col_swing_h, size=size.small)

if i_show_swing and orb_set and pivot_l
    label.new(bar_index[i_pivot_lookback], _pl - tick_off, "▼",
        style=label.style_none, textcolor=i_col_swing_l, size=size.small)

// ─────────────────────────────────────────────────────────────────────────────
//  REFERENCE LINES  (VWAP + Prior Day High/Low)
// ─────────────────────────────────────────────────────────────────────────────

float vwap_val = ta.vwap(hlc3)
plot(i_show_vwap ? vwap_val : na, "VWAP", color=i_col_vwap, linewidth=1)

float pdh_val = request.security(syminfo.tickerid, "D",
    high[1], barmerge.gaps_off, barmerge.lookahead_off)
float pdl_val = request.security(syminfo.tickerid, "D",
    low[1],  barmerge.gaps_off, barmerge.lookahead_off)

plot(i_show_pdhl ? pdh_val : na, "PDH",
    color=i_col_pdhl, style=plot.style_stepline, linewidth=1)
plot(i_show_pdhl ? pdl_val : na, "PDL",
    color=i_col_pdhl, style=plot.style_stepline, linewidth=1)

// ─────────────────────────────────────────────────────────────────────────────
//  VOLUME CONTEXT  (visual only — not an entry filter)
//  Highlights BOS candle background when volume exceeds session average
// ─────────────────────────────────────────────────────────────────────────────

float vol_avg   = ta.sma(volume, i_vol_lookback)
bool  vol_spike = volume > vol_avg

bgcolor(i_show_volume and (buy_signal or sell_signal) and vol_spike
    ? color.new(i_col_vol_hi, 75) : na)
