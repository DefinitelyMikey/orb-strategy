//@version=6

// ═════════════════════════════════════════════════════════════════════════════
//  ORB Strategy V3  |  Pine Script v6
//  Chart     : 5-minute
//  ORB Source: 8:00–8:15 AM ET window, built natively from three 5m bars
//  Session   : 8:00 AM ET open  |  Reset: 18:00 ET
//  Instruments: NQ, MNQ, ES, MES, YM, MYM, GC, MGC
//
//  Entry logic (short; long mirrors):
//    1. Breakout : two CONSECUTIVE bars both body-close below ORB low (any color)
//    2. Liquidity: structural level = high of most recent green→red pair
//                  (falls back to the most recent pre-8AM green→red high)
//    3. Revisit  : price must touch BOTH the structural level AND the ORB band
//                  (any order)
//    4. Floor    : once revisits done, floor = low of most recent red→green pair
//    5. Transfer : floor re-syncs to each new red→green pair (up or down) AND
//                  moves down on a wick that pierces it without a body-close-below
//    6. Entry    : a bearish bar body-closes below the valid floor
//
//  Trade mgmt: SL = entry candle body open | TP = 2:1 RR | BE at 1:1 RR
//  ONE trade per day (all instruments), taken only between 8:00 AM–12:00 PM ET.
//  After that trade CLOSES, all setup drawing stops (ORB box/mid keep going).
// ═════════════════════════════════════════════════════════════════════════════

// ─────────────────────────────────────────────────────────────────────────────
//  INPUTS  (defined before strategy() so they're available at declaration)
// ─────────────────────────────────────────────────────────────────────────────

// ── Backtest Settings ────────────────────────────────────────────────────────
i_commission = input.float(
    2.00, "Commission Per Side ($)", minval=0, step=0.25,
    group="⚙️ Backtest Settings",
    tooltip="Reference only — Pine Script v6 requires constant values in strategy(). Set via Strategy Settings → Properties → Commission.")

i_slippage = input.int(
    1, "Slippage (Ticks)", minval=0,
    group="⚙️ Backtest Settings",
    tooltip="Reference only — set via Strategy Settings → Properties → Slippage.")

// Trading rules are global (same for every instrument): one trade per day,
// taken only between 8:00 AM and 12:00 PM ET. See TRADING WINDOW + DAILY CAP.

// ── ORB Settings ─────────────────────────────────────────────────────────────
i_orb_end = input.int(
    1700, "ORB Box End Time (HHMM ET)", minval=800, maxval=2359,
    group="📐 ORB Settings",
    tooltip="ORB box and midpoint line extend rightward until this time. Default 17:00 ET.")

// ── Visuals ───────────────────────────────────────────────────────────────────
i_show_levels = input.bool(true,  "Show Level Lines (liquidity + floor/ceiling)", group="👁 Visuals")
i_show_volume = input.bool(false, "Show Volume Context",     group="👁 Visuals")
i_show_vwap   = input.bool(false, "Show VWAP",               group="👁 Visuals")
i_show_pdhl   = input.bool(false, "Show Prior Day High/Low", group="👁 Visuals")
i_vol_lookback = input.int(20, "Volume Avg Lookback (bars)", minval=5, maxval=100,
    group="👁 Visuals",
    tooltip="Bars used to compute average volume for context display.")

// ── Colors ────────────────────────────────────────────────────────────────────
i_col_orb_box = input.color(color.new(color.blue,  80), "ORB Box",          group="🎨 Colors")
i_col_orb_mid = input.color(color.new(color.blue,  30), "ORB Midpoint",     group="🎨 Colors")
i_col_liq     = input.color(color.white,                "Liquidity Level",  group="🎨 Colors")
i_col_floor   = input.color(color.orange,               "Floor / Ceiling",  group="🎨 Colors")
i_col_vwap    = input.color(color.new(color.purple, 0), "VWAP",             group="🎨 Colors")
i_col_pdhl    = input.color(color.new(color.gray,   0), "Prior Day H/L",    group="🎨 Colors")
i_col_vol_hi  = input.color(color.new(color.yellow, 0), "Volume Spike",     group="🎨 Colors")

strategy("ORB Strategy V3", overlay=true, process_orders_on_close=true,
    pyramiding=2, max_bars_back=500, max_lines_count=500,
    default_qty_type=strategy.fixed, default_qty_value=1)

// ─────────────────────────────────────────────────────────────────────────────
//  TIME UTILITIES
// ─────────────────────────────────────────────────────────────────────────────

int et_hour   = hour(time,   "America/New_York")
int et_minute = minute(time, "America/New_York")
int et_hhmm   = et_hour * 100 + et_minute

// The 8:00 AM 15m ORB candle = three 5m bars: 08:00, 08:05, 08:10
bool in_orb_window = et_hhmm == 800 or et_hhmm == 805 or et_hhmm == 810
bool new_session   = et_hour == 18 and et_minute == 0

// ─────────────────────────────────────────────────────────────────────────────
//  TRADING WINDOW + DAILY CAP  (global — identical for every instrument)
//  One trade per day, taken only between 8:00 AM and 12:00 PM ET.
// ─────────────────────────────────────────────────────────────────────────────

int  max_trades = 1
bool time_ok    = et_hhmm >= 800 and et_hhmm < 1200

// ─────────────────────────────────────────────────────────────────────────────
//  STATE VARIABLES
// ─────────────────────────────────────────────────────────────────────────────

// ORB
var bool  orb_set    = false
var float orb_high   = na
var float orb_low    = na
var float orb_mid    = na
var int   orb_anchor = na   // bar_index of the 08:00 bar (box left edge)

// Candle-pair levels (tracked every bar, incl. pre-8AM, for fallback)
//   gr_high = high of most recent green→red (bullish→bearish) pair
//   rg_low  = low  of most recent red→green (bearish→bullish) pair
var float gr_high = na
var float rg_low  = na

// Breakout (two consecutive body-closes beyond ORB)
var bool bear_brk = false
var bool bull_brk = false

// Dual-revisit gates (structural level + ORB band)
var bool rev_struct_short = false
var bool rev_orb_short    = false
var bool rev_struct_long  = false
var bool rev_orb_long      = false

// Armed + locked trigger levels
var bool  armed_short    = false
var bool  armed_long     = false
var bool  floor_set      = false
var bool  ceil_set       = false
var float floor_short    = na
var float ceil_long      = na

// Session trade counter
var int entry_count = 0

// True once the day's one trade has CLOSED — suppresses further setup drawing
var bool day_complete = false

// BE management — slot 1 and slot 2 (max 2 simultaneous via pyramiding=2)
var float  s1_entry   = na
var float  s1_sl      = na
var float  s1_tp      = na
var bool   s1_be_done = false
var bool   s1_is_long = true
var string s1_id      = ""

var float  s2_entry   = na
var float  s2_sl      = na
var float  s2_tp      = na
var bool   s2_be_done = false
var bool   s2_is_long = true
var string s2_id      = ""

// Visual objects (persist for extending)
var box  orb_box_obj  = na
var line orb_mid_line = na
var line liq_line_s   = na
var line floor_line_s = na
var line liq_line_l   = na
var line ceil_line_l  = na

// ─────────────────────────────────────────────────────────────────────────────
//  SESSION RESET  (18:00 ET — futures new session)
// ─────────────────────────────────────────────────────────────────────────────

if new_session
    orb_set          := false
    orb_high         := na
    orb_low          := na
    orb_mid          := na
    orb_anchor       := na
    gr_high          := na
    rg_low           := na
    bear_brk         := false
    bull_brk         := false
    rev_struct_short := false
    rev_orb_short    := false
    rev_struct_long  := false
    rev_orb_long     := false
    armed_short      := false
    armed_long       := false
    floor_set        := false
    ceil_set         := false
    floor_short      := na
    ceil_long        := na
    entry_count      := 0
    day_complete     := false
    s1_entry         := na
    s1_sl            := na
    s1_tp            := na
    s1_be_done       := false
    s1_id            := ""
    s2_entry         := na
    s2_sl            := na
    s2_tp            := na
    s2_be_done       := false
    s2_id            := ""
    orb_box_obj      := na
    orb_mid_line     := na
    liq_line_s       := na
    floor_line_s     := na
    liq_line_l       := na
    ceil_line_l      := na

// ─────────────────────────────────────────────────────────────────────────────
//  ORB BUILD  (native 5m aggregation over the 08:00–08:15 window)
//  Accumulate high/low across the three 5m bars (08:00, 08:05, 08:10);
//  latch complete at the 08:10 close (= 8:15) so the range is final before use.
// ─────────────────────────────────────────────────────────────────────────────

if et_hhmm == 800 and not orb_set
    orb_high   := high
    orb_low    := low
    orb_anchor := bar_index
else if (et_hhmm == 805 or et_hhmm == 810) and not orb_set and not na(orb_high)
    orb_high := math.max(orb_high, high)
    orb_low  := math.min(orb_low,  low)

if et_hhmm == 810 and not orb_set and not na(orb_high)
    orb_mid := (orb_high + orb_low) / 2
    orb_set := true

// ─────────────────────────────────────────────────────────────────────────────
//  CANDLE-PAIR TRACKING  (every bar — feeds liquidity levels + floor/ceiling)
// ─────────────────────────────────────────────────────────────────────────────

bool prev_bull = close[1] > open[1]
bool prev_bear = close[1] < open[1]
bool cur_bull  = close > open
bool cur_bear  = close < open

bool pair_gr = prev_bull and cur_bear   // green → red  (bullish → bearish)
bool pair_rg = prev_bear and cur_bull   // red → green  (bearish → bullish)

if pair_gr
    gr_high := math.max(high, high[1])
if pair_rg
    rg_low  := math.min(low,  low[1])

// ─────────────────────────────────────────────────────────────────────────────
//  BREAKOUT  (two CONSECUTIVE bearish/bullish bars body-close beyond ORB)
// ─────────────────────────────────────────────────────────────────────────────

if orb_set and not in_orb_window
    // Two consecutive body-closes beyond the ORB edge. Candle COLOR does not
    // matter — only that the close is outside the range, twice in a row.
    bool bear_now  = close   < orb_low
    bool bear_prev = close[1] < orb_low
    bool bull_now  = close   > orb_high
    bool bull_prev = close[1] > orb_high
    if not bear_brk and bear_now and bear_prev
        bear_brk := true
    if not bull_brk and bull_now and bull_prev
        bull_brk := true

// ─────────────────────────────────────────────────────────────────────────────
//  DUAL REVISIT  (structural level + ORB band — any order, evaluated AFTER break)
//  bear_brk[1] / bull_brk[1] = breakout already valid as of the prior bar,
//  so the breakout candle itself can't satisfy the revisit
// ─────────────────────────────────────────────────────────────────────────────

if bear_brk[1]
    if not rev_struct_short and not na(gr_high) and high >= gr_high
        rev_struct_short := true
    if not rev_orb_short and high >= orb_low
        rev_orb_short := true

if bull_brk[1]
    if not rev_struct_long and not na(rg_low) and low <= rg_low
        rev_struct_long := true
    if not rev_orb_long and low <= orb_high
        rev_orb_long := true

// ─────────────────────────────────────────────────────────────────────────────
//  ARM + LOCK TRIGGER LEVEL + TRANSFER
//  Short floor  = low of most recent red→green pair; locked at arming, then
//    (a) re-syncs to each new red→green pair (up or down), and
//    (b) transfers DOWN on any wick that pierces it without a body-close-below.
//  Long ceiling = high of most recent green→red pair; locked at arming, then
//    (a) re-syncs to each new green→red pair (up or down), and
//    (b) transfers UP on any wick that pierces it without a body-close-above.
//  Re-sync runs first; the later event on a given bar governs.
// ─────────────────────────────────────────────────────────────────────────────

if not armed_short and bear_brk and rev_struct_short and rev_orb_short
    armed_short := true
if armed_short and not floor_set and not na(rg_low)
    floor_short := rg_low
    floor_set   := true
if floor_set and pair_rg
    floor_short := rg_low
if floor_set and not na(floor_short) and low < floor_short and close >= floor_short
    floor_short := low

if not armed_long and bull_brk and rev_struct_long and rev_orb_long
    armed_long := true
if armed_long and not ceil_set and not na(gr_high)
    ceil_long := gr_high
    ceil_set  := true
if ceil_set and pair_gr
    ceil_long := gr_high
if ceil_set and not na(ceil_long) and high > ceil_long and close <= ceil_long
    ceil_long := high

// ─────────────────────────────────────────────────────────────────────────────
//  ENTRY TRIGGER
// ─────────────────────────────────────────────────────────────────────────────

bool bull_bar = close > open
bool bear_bar = close < open

bool s_armed = armed_short and floor_set and not na(floor_short)
bool s_trig  = bear_bar and close < floor_short
bool s_room  = entry_count < max_trades and time_ok
bool sell_signal = s_armed and s_trig and s_room

bool l_armed = armed_long and ceil_set and not na(ceil_long)
bool l_trig  = bull_bar and close > ceil_long
bool l_room  = entry_count < max_trades and time_ok
bool buy_signal = l_armed and l_trig and l_room

// ── Long entry ───────────────────────────────────────────────────────────────
if buy_signal
    float _r  = math.abs(close - open)
    float _sl = open
    float _tp = close + 2.0 * _r
    string _id = "L" + str.tostring(entry_count + 1)
    strategy.entry(_id, strategy.long)
    strategy.exit(_id + "x", _id, stop=_sl, limit=_tp)
    if na(s1_entry)
        s1_entry   := close
        s1_sl      := _sl
        s1_tp      := _tp
        s1_be_done := false
        s1_is_long := true
        s1_id      := _id
    else
        s2_entry   := close
        s2_sl      := _sl
        s2_tp      := _tp
        s2_be_done := false
        s2_is_long := true
        s2_id      := _id
    entry_count := entry_count + 1
    // reset long setup so re-entry needs a fresh revisit + ceiling
    armed_long      := false
    rev_struct_long := false
    rev_orb_long    := false
    ceil_set        := false
    ceil_long       := na
    liq_line_l      := na
    ceil_line_l     := na

// ── Short entry ──────────────────────────────────────────────────────────────
if sell_signal
    float _r  = math.abs(close - open)
    float _sl = open
    float _tp = close - 2.0 * _r
    string _id = "S" + str.tostring(entry_count + 1)
    strategy.entry(_id, strategy.short)
    strategy.exit(_id + "x", _id, stop=_sl, limit=_tp)
    if na(s1_entry)
        s1_entry   := close
        s1_sl      := _sl
        s1_tp      := _tp
        s1_be_done := false
        s1_is_long := false
        s1_id      := _id
    else
        s2_entry   := close
        s2_sl      := _sl
        s2_tp      := _tp
        s2_be_done := false
        s2_is_long := false
        s2_id      := _id
    entry_count := entry_count + 1
    // reset short setup so re-entry needs a fresh revisit + floor
    armed_short      := false
    rev_struct_short := false
    rev_orb_short    := false
    floor_set        := false
    floor_short      := na
    liq_line_s       := na
    floor_line_s     := na

// ─────────────────────────────────────────────────────────────────────────────
//  BREAKEVEN MANAGEMENT  (move SL to entry when 1:1 RR reached)
// ─────────────────────────────────────────────────────────────────────────────

if not na(s1_entry) and not s1_be_done and s1_id != ""
    float _r  = math.abs(s1_entry - s1_sl)
    bool  hit = s1_is_long ? high >= s1_entry + _r : low <= s1_entry - _r
    if hit
        strategy.exit(s1_id + "x", s1_id, stop=s1_entry, limit=s1_tp)
        s1_be_done := true

if not na(s2_entry) and not s2_be_done and s2_id != ""
    float _r  = math.abs(s2_entry - s2_sl)
    bool  hit = s2_is_long ? high >= s2_entry + _r : low <= s2_entry - _r
    if hit
        strategy.exit(s2_id + "x", s2_id, stop=s2_entry, limit=s2_tp)
        s2_be_done := true

// ─────────────────────────────────────────────────────────────────────────────
//  POSITION CLOSE HANDLING  (BE stop-out or TP hit)
//  Clear slots + reset both setups so a fresh setup can build for re-entry
// ─────────────────────────────────────────────────────────────────────────────

bool pos_closed = strategy.position_size == 0 and
                  strategy.position_size[1] != 0 and
                  not new_session

if pos_closed
    day_complete     := true
    s1_entry         := na
    s1_sl            := na
    s1_tp            := na
    s1_be_done       := false
    s1_id            := ""
    s2_entry         := na
    s2_sl            := na
    s2_tp            := na
    s2_be_done       := false
    s2_id            := ""
    armed_short      := false
    armed_long       := false
    rev_struct_short := false
    rev_orb_short    := false
    rev_struct_long  := false
    rev_orb_long     := false
    floor_set        := false
    ceil_set         := false
    floor_short      := na
    ceil_long        := na
    liq_line_s       := na
    floor_line_s     := na
    liq_line_l       := na
    ceil_line_l      := na

// ─────────────────────────────────────────────────────────────────────────────
//  ORB VISUALS  (box + midpoint, extending to i_orb_end)
// ─────────────────────────────────────────────────────────────────────────────

if orb_set and na(orb_box_obj) and not na(orb_anchor)
    orb_box_obj  := box.new(orb_anchor, orb_high, bar_index + 1, orb_low,
                             border_color=i_col_orb_box, bgcolor=i_col_orb_box)
    orb_mid_line := line.new(orb_anchor, orb_mid, bar_index + 1, orb_mid,
                              color=i_col_orb_mid, style=line.style_dashed, width=1)

if orb_set and not na(orb_box_obj) and et_hhmm <= i_orb_end
    box.set_right(orb_box_obj, bar_index + 1)
    line.set_x2(orb_mid_line, bar_index + 1)

// ─────────────────────────────────────────────────────────────────────────────
//  LEVEL LINE VISUALS  (liquidity level while waiting, floor/ceiling once locked)
// ─────────────────────────────────────────────────────────────────────────────

// Short liquidity level (the structural high to revisit) — drawn until revisited
if i_show_levels and not day_complete and bear_brk and not rev_struct_short and not na(gr_high)
    if na(liq_line_s)
        liq_line_s := line.new(bar_index, gr_high, bar_index + 1, gr_high,
            color=i_col_liq, style=line.style_dashed, width=1)
    else
        line.set_y1(liq_line_s, gr_high)
        line.set_y2(liq_line_s, gr_high)
        line.set_x2(liq_line_s, bar_index + 1)

// Short floor (trigger) — drawn + transferred while armed
if i_show_levels and not day_complete and floor_set and not na(floor_short)
    if na(floor_line_s)
        floor_line_s := line.new(bar_index, floor_short, bar_index + 1, floor_short,
            color=i_col_floor, style=line.style_dashed, width=1)
    else
        line.set_y1(floor_line_s, floor_short)
        line.set_y2(floor_line_s, floor_short)
        line.set_x2(floor_line_s, bar_index + 1)

// Long liquidity level (the structural low to revisit) — drawn until revisited
if i_show_levels and not day_complete and bull_brk and not rev_struct_long and not na(rg_low)
    if na(liq_line_l)
        liq_line_l := line.new(bar_index, rg_low, bar_index + 1, rg_low,
            color=i_col_liq, style=line.style_dashed, width=1)
    else
        line.set_y1(liq_line_l, rg_low)
        line.set_y2(liq_line_l, rg_low)
        line.set_x2(liq_line_l, bar_index + 1)

// Long ceiling (trigger) — drawn + transferred while armed
if i_show_levels and not day_complete and ceil_set and not na(ceil_long)
    if na(ceil_line_l)
        ceil_line_l := line.new(bar_index, ceil_long, bar_index + 1, ceil_long,
            color=i_col_floor, style=line.style_dashed, width=1)
    else
        line.set_y1(ceil_line_l, ceil_long)
        line.set_y2(ceil_line_l, ceil_long)
        line.set_x2(ceil_line_l, bar_index + 1)

// ─────────────────────────────────────────────────────────────────────────────
//  REFERENCE LINES  (VWAP + Prior Day High/Low)
// ─────────────────────────────────────────────────────────────────────────────

float vwap_val = ta.vwap(hlc3)
plot(i_show_vwap ? vwap_val : na, "VWAP", color=i_col_vwap, linewidth=1)

float pdh_val = request.security(syminfo.tickerid, "D",
    high[1], barmerge.gaps_off, barmerge.lookahead_off)
float pdl_val = request.security(syminfo.tickerid, "D",
    low[1],  barmerge.gaps_off, barmerge.lookahead_off)

plot(i_show_pdhl ? pdh_val : na, "PDH",
    color=i_col_pdhl, style=plot.style_stepline, linewidth=1)
plot(i_show_pdhl ? pdl_val : na, "PDL",
    color=i_col_pdhl, style=plot.style_stepline, linewidth=1)

// ─────────────────────────────────────────────────────────────────────────────
//  VOLUME CONTEXT  (visual only — not an entry filter)
//  Highlights entry candle background when volume exceeds session average
// ─────────────────────────────────────────────────────────────────────────────

float vol_avg   = ta.sma(volume, i_vol_lookback)
bool  vol_spike = volume > vol_avg

bgcolor(i_show_volume and not day_complete and (buy_signal or sell_signal) and vol_spike
    ? color.new(i_col_vol_hi, 75) : na)
